class Deployer:
    """Handles deployment to remote destinations."""

    def __init__(self, destination: Destination):
        self.destination = destination
        self._control_path: str | None = None
        self._control_host: str | None = None

    def start_multiplexing(self):
        """Start an SSH ControlMaster connection for reuse across commands."""
        target = self.destination.target
        if ":" in target:
            host = target.rsplit(":", 1)[0]
        else:
            host = target

        self._control_host = host
        self._control_path = f"/tmp/dotfiles-bundle-ssh-{os.getpid()}"

        ssh_opts = self.destination.ssh_opts.split() if self.destination.ssh_opts else []
        cmd = [
            "ssh", "-fNM",
            "-o", f"ControlPath={self._control_path}",
            "-o", "ControlPersist=60",
        ] + ssh_opts + [host]

        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            self._control_path = None
            return False
        return True

    def stop_multiplexing(self):
        """Close the SSH ControlMaster connection."""
        if self._control_path and self._control_host:
            subprocess.run(
                ["ssh", "-O", "exit", "-o", f"ControlPath={self._control_path}", self._control_host],
                capture_output=True, text=True,
            )
            self._control_path = None

    def _ssh_opts(self) -> list[str]:
        """Build SSH options list, including ControlMaster if active."""
        opts = self.destination.ssh_opts.split() if self.destination.ssh_opts else []
        if self._control_path:
            opts.extend(["-o", f"ControlPath={self._control_path}"])
        return opts

    def preview(self, package_dir: Path, extra_excludes: list[str] | None = None) -> tuple[list[str], list[str]]:
        """Preview what would be changed using rsync dry-run.

        Returns:
            Tuple of (changed_files, unchanged_files)
        """
        ssh_opts = self._ssh_opts()

        cmd = [
            "rsync",
            "-avzcn",  # archive, verbose, compress, checksum, dry-run
            "--itemize-changes",
            "--exclude=install-packages.sh",
            "--exclude=README.md",
            "--exclude=util/",
        ]

        for ex in (extra_excludes or []):
            cmd.extend(["--exclude", ex])

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([
            f"{package_dir}/",
            self.destination.target,
        ])

        result = subprocess.run(cmd, capture_output=True, text=True)

        # Parse itemized output for changed files
        # Format: YXcstpoguax where Y indicates transfer type
        # '>' = sending, '<' = receiving, 'c' = creating, '.' = no update
        changes = []
        unchanged = []
        for line in result.stdout.strip().split("\n"):
            if not line or line.startswith("sending") or line.startswith("total"):
                continue

            parts = line.split(" ", 1)
            if len(parts) < 2:
                continue

            filename = parts[1]
            if filename.endswith("/"):
                continue

            # First char indicates transfer type
            if line[0] in ">c*<":
                changes.append(filename)
            elif line[0] == ".":
                unchanged.append(filename)

        return changes, unchanged

    def deploy(self, package_dir: Path, extra_excludes: list[str] | None = None) -> tuple[bool, list[str]]:
        """Deploy to destination.

        Returns:
            Tuple of (success, list of synced files)
        """
        ssh_opts = self._ssh_opts()

        cmd = [
            "rsync",
            "-avzc",  # archive, verbose, compress, checksum
            "--itemize-changes",  # Show what's being transferred
            "--exclude=install-packages.sh",
            "--exclude=README.md",
            "--exclude=util/",
        ]

        for ex in (extra_excludes or []):
            cmd.extend(["--exclude", ex])

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([
            f"{package_dir}/",
            self.destination.target,
        ])

        result = subprocess.run(cmd, capture_output=True, text=True)

        # Parse itemized output for synced files
        synced = []
        for line in result.stdout.strip().split("\n"):
            if not line or line.startswith("sending") or line.startswith("total"):
                continue

            parts = line.split(" ", 1)
            if len(parts) < 2:
                continue

            filename = parts[1]
            if filename.endswith("/"):
                continue

            # First char indicates transfer type: > = sending, c = creating
            if line[0] in ">c*<":
                synced.append(filename)

        return result.returncode == 0, synced

    def pull(self, dest_dir: Path, files_from: Path) -> bool:
        """Pull specific files from remote to local directory.

        Args:
            dest_dir: Local directory to pull files into
            files_from: Path to file listing relative paths to pull

        Returns:
            True if rsync succeeded
        """
        ssh_opts = self._ssh_opts()

        # Build source path — rsync with --files-from treats ~ literally,
        # so use empty path after : (defaults to home directory)
        source = self.destination.target
        if ":" in source:
            host, path = source.rsplit(":", 1)
            if path.rstrip("/") == "~":
                source = host + ":"
            elif not path.endswith("/"):
                source += "/"
        elif not source.endswith("/"):
            source += "/"

        cmd = ["rsync", "-azc", "--ignore-missing-args", f"--files-from={files_from}"]

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([source, f"{dest_dir}/"])

        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0 and result.stderr:
            print(f"rsync error: {result.stderr.strip()}", file=sys.stderr)
        return result.returncode == 0

    def pull_with_patterns(
        self, dest_dir: Path, include_patterns: list[str], exclude_patterns: list[str]
    ) -> bool:
        """Pull files from remote using include/exclude patterns.

        Unlike pull() with --files-from, this properly recurses into directories
        to detect new remote files.
        """
        ssh_opts = self._ssh_opts()

        source = self.destination.target
        if ":" in source:
            host, path = source.rsplit(":", 1)
            if path.rstrip("/") == "~":
                source = host + ":"
            elif not path.endswith("/"):
                source += "/"
        elif not source.endswith("/"):
            source += "/"

        cmd = ["rsync", "-azc", "--prune-empty-dirs"]

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        # Specific excludes first (first matching rule wins in rsync)
        for pattern in exclude_patterns:
            cmd.extend(["--exclude", pattern])

        # Compute parent directories that must be included for rsync to descend
        parents: set[str] = set()
        for pattern in include_patterns:
            clean = pattern.rstrip("/")
            parts = Path(clean).parts
            for i in range(len(parts) - 1):
                parents.add(str(Path(*parts[: i + 1])) + "/")

        for parent in sorted(parents):
            cmd.extend(["--include", parent])

        # Include patterns: directories get recursive **, files are literal
        for pattern in include_patterns:
            if pattern.endswith("/"):
                cmd.extend(["--include", pattern])
                cmd.extend(["--include", pattern + "**"])
            else:
                cmd.extend(["--include", pattern])

        # Exclude everything else
        cmd.extend(["--exclude", "*"])

        cmd.extend([source, f"{dest_dir}/"])

        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0 and result.stderr:
            print(f"rsync error: {result.stderr.strip()}", file=sys.stderr)
        return result.returncode == 0


