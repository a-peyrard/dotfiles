# ============================================================================


def backup_remote_files(deployer: Deployer, changed_files: list[str]) -> str | None:
    """Back up changed files on the remote before overwriting.

    Returns the backup directory name, or None on failure.
    """
    if not changed_files:
        return None

    from datetime import datetime, timezone

    target = deployer.destination.target
    if ":" in target:
        host = target.rsplit(":", 1)[0]
    else:
        host = target

    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S")
    backup_dir = f"~/{BACKUP_REMOTE_DIR}/{timestamp}"

    # Build SSH command to create backup dir and copy files
    copy_cmds = [f"mkdir -p {backup_dir}"]
    for fp in changed_files:
        parent = str(Path(fp).parent)
        if parent and parent != ".":
            copy_cmds.append(f"mkdir -p {backup_dir}/{parent}")
        copy_cmds.append(f"cp -p ~/{fp} {backup_dir}/{fp} 2>/dev/null")

    # Rotate old backups: keep only the last MAX_BACKUPS
    copy_cmds.append(
        f"cd ~/{BACKUP_REMOTE_DIR} && ls -1d */ 2>/dev/null | head -n -{MAX_BACKUPS} | xargs rm -rf 2>/dev/null"
    )

    cmd = ["ssh"] + deployer._ssh_opts() + [host, " && ".join(copy_cmds)]

    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode == 0:
        return timestamp
    return None


# ============================================================================
# Git Safety
# ============================================================================


def _check_repos_clean() -> list[str]:
    """Check if dotfiles and dotfiles-private repos have uncommitted changes.

    Returns list of error messages (empty if both repos are clean).
    """
    errors = []
    private_dir = Path(os.environ.get(
        "DOTFILES_PRIVATE", str(REPO_ROOT.parent / "dotfiles-private")
    ))

    for repo_dir, label in [(REPO_ROOT, "dotfiles"), (private_dir, "dotfiles-private")]:
        if not (repo_dir / ".git").exists():
            continue
        result = subprocess.run(
            ["git", "-C", str(repo_dir), "status", "--porcelain"],
            capture_output=True, text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            dirty_files = [
                f"    {line}" for line in result.stdout.strip().split("\n")
            ]
            errors.append(
                f"{Color.YELLOW}{label}{Color.RESET} has uncommitted changes:\n"
                + "\n".join(dirty_files)
            )

    return errors


