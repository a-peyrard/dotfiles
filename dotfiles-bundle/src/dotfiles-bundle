# Deployer
# ============================================================================


class Deployer:
    """Handles deployment to remote destinations."""

    def __init__(self, destination: Destination):
        self.destination = destination

    def preview(self, package_dir: Path) -> tuple[list[str], list[str]]:
        """Preview what would be changed using rsync dry-run.

        Returns:
            Tuple of (changed_files, unchanged_files)
        """
        ssh_opts = self.destination.ssh_opts.split() if self.destination.ssh_opts else []

        cmd = [
            "rsync",
            "-avzcn",  # archive, verbose, compress, checksum, dry-run
            "--itemize-changes",
            "--exclude=install-packages.sh",
            "--exclude=README.md",
            "--exclude=util/",
        ]

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([
            f"{package_dir}/",
            self.destination.target,
        ])

        result = subprocess.run(cmd, capture_output=True, text=True)

        # Parse itemized output for changed files
        # Format: YXcstpoguax where Y indicates transfer type
        # '>' = sending, '<' = receiving, 'c' = creating, '.' = no update
        changes = []
        unchanged = []
        for line in result.stdout.strip().split("\n"):
            if not line or line.startswith("sending") or line.startswith("total"):
                continue

            parts = line.split(" ", 1)
            if len(parts) < 2:
                continue

            filename = parts[1]
            if filename.endswith("/"):
                continue

            # First char indicates transfer type
            if line[0] in ">c*<":
                changes.append(filename)
            elif line[0] == ".":
                unchanged.append(filename)

        return changes, unchanged

    def deploy(self, package_dir: Path) -> tuple[bool, list[str]]:
        """Deploy to destination.

        Returns:
            Tuple of (success, list of synced files)
        """
        ssh_opts = self.destination.ssh_opts.split() if self.destination.ssh_opts else []

        cmd = [
            "rsync",
            "-avzc",  # archive, verbose, compress, checksum
            "--itemize-changes",  # Show what's being transferred
            "--exclude=install-packages.sh",
            "--exclude=README.md",
            "--exclude=util/",
        ]

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([
            f"{package_dir}/",
            self.destination.target,
        ])

        result = subprocess.run(cmd, capture_output=True, text=True)

        # Parse itemized output for synced files
        synced = []
        for line in result.stdout.strip().split("\n"):
            if not line or line.startswith("sending") or line.startswith("total"):
                continue

            parts = line.split(" ", 1)
            if len(parts) < 2:
                continue

            filename = parts[1]
            if filename.endswith("/"):
                continue

            # First char indicates transfer type: > = sending, c = creating
            if line[0] in ">c*<":
                synced.append(filename)

        return result.returncode == 0, synced

    def pull(self, dest_dir: Path, files_from: Path) -> bool:
        """Pull specific files from remote to local directory.

        Args:
            dest_dir: Local directory to pull files into
            files_from: Path to file listing relative paths to pull

        Returns:
            True if rsync succeeded
        """
        ssh_opts = self.destination.ssh_opts.split() if self.destination.ssh_opts else []

        source = self.destination.target
        if not source.endswith("/"):
            source += "/"

        cmd = ["rsync", "-azc", f"--files-from={files_from}"]

        if ssh_opts:
            cmd.extend(["-e", f"ssh {' '.join(ssh_opts)}"])

        cmd.extend([source, f"{dest_dir}/"])

        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0 and result.stderr:
            print(f"rsync error: {result.stderr.strip()}", file=sys.stderr)
        return result.returncode == 0


# ============================================================================
# Provenance & Remote Change Detection
# ============================================================================


def build_provenance_map(
    bundle_name: str, files: list[ResolvedFile], override_manager: OverrideManager
) -> dict[str, FileProvenance]:
    """Build a map of deployed file paths to their source provenance.

    Used by pull to know where to write remote changes back to.
    """
    provenance: dict[str, FileProvenance] = {}

    for resolved in files:
        overrides = override_manager.find_overrides(bundle_name, resolved.relative_path)

        if not overrides:
            provenance[resolved.relative_path] = FileProvenance(
                deployed_path=resolved.relative_path,
                source_type=resolved.source_type,
                source_path=resolved.source_path,
                has_overrides=False,
                override_mode=None,
            )
        elif len(overrides) == 1 and overrides[0].mode == "replace":
            provenance[resolved.relative_path] = FileProvenance(
                deployed_path=resolved.relative_path,
                source_type="override",
                source_path=overrides[0].path,
                has_overrides=False,
                override_mode="replace",
            )
        else:
            # Composite: prepend, append, merge, or multiple overrides
            provenance[resolved.relative_path] = FileProvenance(
                deployed_path=resolved.relative_path,
                source_type=resolved.source_type,
                source_path=resolved.source_path,
                has_overrides=True,
                override_mode=None,
            )

    # Additions (overwrite regular files if overlap, matching PackageBuilder behavior)
    additions = override_manager.find_additions(bundle_name)
    for addition in additions:
        if addition.is_directory:
            for src_file in addition.source_path.rglob("*"):
                if src_file.is_file():
                    rel = src_file.relative_to(addition.source_path)
                    deployed = str(Path(addition.target_path) / rel)
                    provenance[deployed] = FileProvenance(
                        deployed_path=deployed,
                        source_type="addition",
                        source_path=src_file,
                        has_overrides=False,
                        override_mode="add",
                    )
        else:
            provenance[addition.target_path] = FileProvenance(
                deployed_path=addition.target_path,
                source_type="addition",
                source_path=addition.source_path,
                has_overrides=False,
                override_mode="add",
            )

    return provenance


def _check_remote_changes(
    deployer: Deployer, package_dir: Path, provenance: dict[str, FileProvenance]
) -> list[str] | None:
    """Check which files on remote differ from local package.

    Returns list of changed file paths, or None if the check failed.
    """
    with tempfile.TemporaryDirectory() as pull_tmp:
        files_list = Path(pull_tmp) / "files.txt"
        file_paths = sorted(provenance.keys())
        files_list.write_text("\n".join(file_paths) + "\n")

        remote_dir = Path(pull_tmp) / "remote"
        remote_dir.mkdir()

        if not deployer.pull(remote_dir, files_list):
            return None

        changed = []
        for fp in file_paths:
            local = package_dir / fp
            remote = remote_dir / fp
            if not remote.exists() or not local.exists():
                continue
            if local.read_bytes() != remote.read_bytes():
                changed.append(fp)

        return changed


