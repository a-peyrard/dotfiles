def cmd_list(args):
    """List available bundles and their destinations."""
    resolver = BundleResolver()
    bundles = resolver.list_bundles()

    header("Available bundles:")
    if bundles:
        for bundle in bundles:
            extends_info = f" (extends: {bundle.extends})" if bundle.extends else ""
            target_info = f" [{bundle.target}]" if bundle.target != "any" else ""

            # Check if destination is configured
            dest = load_destination_for_bundle(bundle.name)
            dest_info = f" -> {dest.target}" if dest else " (no destination)"

            info(f"{bundle.name:<12} {bundle.description}{extends_info}{target_info}{dest_info}")
    else:
        info("No bundles found. Create bundles/<name>/bundle.toml")
    print()


def cmd_show(args):
    """Show what a bundle includes."""
    resolver = BundleResolver()
    config = resolver.resolve(args.name)

    file_resolver = FileResolver()
    files = file_resolver.resolve_bundle(config)

    # Load destination
    dest = load_destination_for_bundle(args.name)

    # Header info
    print(f"\n{Color.BOLD}Bundle:{Color.RESET} {Color.CYAN}{config.name}{Color.RESET}")
    print(f"{Color.BOLD}Description:{Color.RESET} {config.description}")
    if config.extends:
        print(f"{Color.BOLD}Extends:{Color.RESET} {config.extends}")
    print(f"{Color.BOLD}Target:{Color.RESET} {Color.YELLOW}{config.target}{Color.RESET}")
    if dest:
        print(f"{Color.BOLD}Destination:{Color.RESET} {Color.GREEN}{dest.target}{Color.RESET}")
    else:
        print(f"{Color.BOLD}Destination:{Color.RESET} {Color.DIM}(not configured){Color.RESET}")
    print(f"{Color.BOLD}Packages:{Color.RESET} {len(config.packages_install)} packages")

    # Limit for non-verbose mode
    limit = None if args.verbose else 15

    # Group by source type
    by_source = defaultdict(list)
    for f in files:
        by_source[f.source_type].append(f)

    for source_type in ["links", "links-in-depth", "runtime"]:
        if source_type in by_source:
            header(f"{Color.MAGENTA}{source_type.upper()}{Color.RESET} ({len(by_source[source_type])} files):")
            sorted_files = sorted(by_source[source_type], key=lambda x: x.relative_path)
            display_files = sorted_files if limit is None else sorted_files[:limit]
            for f in display_files:
                info(f.relative_path)
            if limit and len(by_source[source_type]) > limit:
                info(f"{Color.DIM}... and {len(by_source[source_type]) - limit} more (use -v for all){Color.RESET}")

    # Check for overrides
    override_dir = BUNDLES_DIR / args.name
    if override_dir.exists() and any(override_dir.iterdir()):
        header(f"{Color.MAGENTA}OVERRIDES:{Color.RESET}")
        skip_files = {"bundle.toml", "destination.private", "destination.private.example"}
        for override_file in sorted(override_dir.rglob("*")):
            if override_file.is_file() and override_file.name not in skip_files:
                rel = override_file.relative_to(override_dir)
                if str(rel).endswith(".private"):
                    info(f"{Color.YELLOW}{rel}{Color.RESET} {Color.DIM}(private){Color.RESET}")
                else:
                    info(f"{Color.GREEN}{rel}{Color.RESET}")
    print()


def cmd_build(args):
    """Build bundle to tarball."""
    bundle_name = args.name
    output = Path(args.output) if args.output else Path(f"/tmp/dotfiles-{bundle_name}.tar.gz")

    print(f"\nBuilding bundle: {bundle_name}")

    resolver = BundleResolver()
    config = resolver.resolve(bundle_name)

    file_resolver = FileResolver()
    files = file_resolver.resolve_bundle(config)

    info(f"Resolved {len(files)} files")
    info(f"Target platform: {config.target}")

    builder = PackageBuilder(bundle_name, config)
    builder.build(files, output)

    size = output.stat().st_size
    print(f"\nBuilt: {output} ({format_size(size)})")


def cmd_deploy(args):
    """Build and deploy bundle to destination."""
    bundle_name = args.name

    # Load destination for this bundle
    dest = load_destination_for_bundle(bundle_name)

    if not dest:
        die(
            f"No destination configured for bundle '{bundle_name}'.\n"
            f"Create bundles/{bundle_name}/destination.private with:\n"
            f"  target = \"user@host:~\"\n"
            f"  ssh_opts = \"\"  # optional"
        )

    # -y/--yes implies --apply
    do_deploy = args.apply or args.yes

    repo_errors = _check_repos_clean()
    if repo_errors:
        print(f"\n{Color.YELLOW}Warning: uncommitted changes detected — deploy may be incomplete.{Color.RESET}")
        for err in repo_errors:
            print(f"\n{err}")

    print(f"\nBuilding bundle: {bundle_name}")
    print(f"Destination: {dest.target}")

    # Build
    resolver = BundleResolver()
    config = resolver.resolve(bundle_name)

    file_resolver = FileResolver()
    files = file_resolver.resolve_bundle(config)

    with tempfile.TemporaryDirectory() as temp_dir:
        package_dir = Path(temp_dir) / f"dotfiles-{bundle_name}"
        package_dir.mkdir()

        # Build package in temp directory
        builder = PackageBuilder(bundle_name, config)
        for resolved in files:
            builder._copy_file(resolved, package_dir)

        # Copy additions
        builder._copy_additions(package_dir)

        if config.packages_install and UTIL_DIR.exists():
            shutil.copytree(UTIL_DIR, package_dir / "util")
            builder._generate_install_script(package_dir)
            builder._generate_readme(package_dir)

        deployer = Deployer(dest)
        multiplexing = deployer.start_multiplexing()
        if multiplexing:
            print("  SSH connection established.")

        # -y/--yes implies --apply
        do_apply = args.apply or args.yes

        # Pre-deploy remote change check (unless --force)
        remote_only_files = []
        deploy_conflict_files = []
        if not args.force:
            provenance = build_provenance_map(bundle_name, files, builder.override_manager)
            manifest = read_manifest(bundle_name)
            print("\nChecking remote for changes...")

            # Pull remote files for comparison
            with tempfile.TemporaryDirectory() as check_tmp:
                files_list = Path(check_tmp) / "files.txt"
                check_paths = sorted(provenance.keys())
                files_list.write_text("\n".join(check_paths) + "\n")
                check_remote_dir = Path(check_tmp) / "remote"
                check_remote_dir.mkdir()

                if deployer.pull(check_remote_dir, files_list):
                    classifications = classify_changes(
                        package_dir, check_remote_dir, check_paths, manifest,
                    )

                    remote_only = [f for f, c in classifications.items() if c == "remote_only"]
                    local_only = [f for f, c in classifications.items() if c == "local_only"]
                    conflicts = [f for f, c in classifications.items() if c == "both"]
                    no_manifest = [f for f, c in classifications.items() if c == "no_manifest"]

                    # Apply pull_ignore to suppress noise
                    if config.pull_ignore:
                        _ign = lambda fp: any(glob_match(p, fp) for p in config.pull_ignore)
                        remote_only = [f for f in remote_only if not _ign(f)]

                    if not remote_only and not local_only and not conflicts and not no_manifest:
                        print("  No changes detected.")
                    else:
                        if remote_only:
                            print(f"\n  {len(remote_only)} remote-only change(s) — will be preserved (not overwritten):")
                            for f in remote_only:
                                info(f"{Color.CYAN}{f}{Color.RESET}")
                            remote_only_files = remote_only

                        if local_only:
                            print(f"\n  {len(local_only)} local-only change(s) — will be deployed.")

                        if conflicts:
                            deploy_conflict_files = conflicts
                            print(f"\n  {Color.YELLOW}{len(conflicts)} conflict(s) — changed on both sides:{Color.RESET}")
                            for f in conflicts:
                                info(f"{Color.YELLOW}{f}{Color.RESET}")
                            print(f"\n  Run '{Color.CYAN}dotfiles-bundle pull {bundle_name}{Color.RESET}' to resolve.")
                            if do_apply and not args.yes:
                                response = input("\nContinue with deploy (conflicts will be overwritten)? [y/N]: ").strip().lower()
                                if response != "y":
                                    print("Aborted.")
                                    return

                        if no_manifest:
                            print(f"\n  {Color.YELLOW}{len(no_manifest)} file(s) differ (no manifest — unknown direction):{Color.RESET}")
                            for f in no_manifest:
                                info(f)
                            if do_apply and not args.yes:
                                response = input("\nContinue with deploy? [y/N]: ").strip().lower()
                                if response != "y":
                                    print("Aborted.")
                                    return
                else:
                    print(f"  {Color.YELLOW}Could not check remote (connection failed){Color.RESET}")

        # Preview
        header("Preview (rsync --dry-run):")
        changes, unchanged = deployer.preview(package_dir, extra_excludes=remote_only_files + deploy_conflict_files)

        if not changes:
            print(f"No changes to deploy. ({len(unchanged)} files already up to date)")
            # Still write manifest (config may have changed)
            manifest = build_manifest(bundle_name, files, builder.override_manager, package_dir)
            write_manifest(bundle_name, manifest)
            log_operation(bundle_name, "deploy", "no changes")
            return

        # Show unchanged summary first
        if unchanged:
            print(f"{len(unchanged)} files unchanged", end="")
            if args.verbose:
                print(":")
                for f in unchanged:
                    print(f"  (=) {f}")
            else:
                print()
            print()

        # Show changes
        print(f"{len(changes)} files to sync:")
        for change in changes[:20] if not args.verbose else changes:
            info(f"  {change}")
        if len(changes) > 20 and not args.verbose:
            info(f"  ... and {len(changes) - 20} more")

        print(f"\n{len(changes)} files will be synced to {dest.target}")

        if not do_apply:
            print(f"\nRun with {Color.CYAN}--apply{Color.RESET} to deploy.")
            return

        # Confirm (unless -y)
        if not args.yes:
            response = input("\nProceed? [y/N]: ").strip().lower()
            if response != "y":
                print("Aborted.")
                return

        # Back up changed files on remote before overwriting
        if changes and not args.force:
            print("\nBacking up remote files...")
            backup_ts = backup_remote_files(deployer, changes)
            if backup_ts:
                print(f"  Backed up to ~/{BACKUP_REMOTE_DIR}/{backup_ts}/")
            else:
                print(f"  {Color.YELLOW}Backup failed. Aborting deploy.{Color.RESET}")
                print(f"  Use {Color.CYAN}--force{Color.RESET} to skip backup.")
                return

        print("\nDeploying...")
        success, synced = deployer.deploy(package_dir, extra_excludes=remote_only_files + deploy_conflict_files)
        if success:
            if synced:
                print(f"\n{len(synced)} file(s) synced.")
            else:
                print("No changes - already up to date.")

            # Write deployment manifest locally
            manifest = build_manifest(bundle_name, files, builder.override_manager, package_dir)
            if write_manifest(bundle_name, manifest):
                print(f"  Manifest written to {_manifest_path(bundle_name).relative_to(REPO_ROOT)}")
            else:
                print(f"  {Color.YELLOW}Failed to write manifest{Color.RESET}")

            log_operation(bundle_name, "deploy", f"{len(synced)} file(s) synced")
            print("Deployment complete!")
        else:
            die("Deployment failed")

        deployer.stop_multiplexing()


def _prompt_new_file_placement(rel_path: str, bundle_name: str) -> str:
    """Prompt user for where to place a new remote file.

    Returns: 'private', 'public', 'base', or 'skip'
    """
    print(f"\n  {Color.CYAN}{rel_path}{Color.RESET}")
    print(f"    [1] bundle private  ({Color.DIM}bundles/{bundle_name}/...add.private{Color.RESET})")
    print(f"    [2] bundle public   ({Color.DIM}bundles/{bundle_name}/...add{Color.RESET})")
    print(f"    [3] base public     ({Color.DIM}links/{rel_path}{Color.RESET})")
    print(f"    [s] skip")
    while True:
        choice = input("    Choice [1]: ").strip().lower() or "1"
        if choice in ("1", "2", "3", "s"):
            return {"1": "private", "2": "public", "3": "base", "s": "skip"}[choice]
        print("    Invalid choice. Enter 1, 2, 3, or s.")


def _place_new_file(
    rel_path: str, content: bytes, placement: str, bundle_name: str, mode: int | None = None
) -> bool:
    """Place a new file according to user's choice. Returns True on success."""
    private_dir = Path(os.environ.get("DOTFILES_PRIVATE", str(REPO_ROOT.parent / "dotfiles-private")))

    if placement == "private":
        if not private_dir.exists():
            print(f"    {Color.YELLOW}Private repo not found at {private_dir}{Color.RESET}")
            return False

        # Write to private repo
        private_path = private_dir / "bundles" / bundle_name / f"{rel_path}.add.private"
        private_path.parent.mkdir(parents=True, exist_ok=True)
        private_path.write_bytes(content)
        if mode is not None:
            private_path.chmod(mode)

        # Create absolute symlink in public repo (matches dotfiles-private-link convention)
        symlink_path = REPO_ROOT / "bundles" / bundle_name / f"{rel_path}.add.private"
        symlink_path.parent.mkdir(parents=True, exist_ok=True)
        if symlink_path.exists() or symlink_path.is_symlink():
            symlink_path.unlink()
        symlink_path.symlink_to(private_path)

        try:
            disp = symlink_path.relative_to(REPO_ROOT)
        except ValueError:
            disp = symlink_path
        info(f"{Color.GREEN}Placed:{Color.RESET} {rel_path} -> {disp} (private)")
        return True

    elif placement == "public":
        add_path = REPO_ROOT / "bundles" / bundle_name / f"{rel_path}.add"
        add_path.parent.mkdir(parents=True, exist_ok=True)
        add_path.write_bytes(content)
        if mode is not None:
            add_path.chmod(mode)

        try:
            disp = add_path.relative_to(REPO_ROOT)
        except ValueError:
            disp = add_path
        info(f"{Color.GREEN}Placed:{Color.RESET} {rel_path} -> {disp}")
        return True

    elif placement == "base":
        base_path = LINKS_DIR / rel_path
        base_path.parent.mkdir(parents=True, exist_ok=True)
        base_path.write_bytes(content)
        if mode is not None:
            base_path.chmod(mode)

        try:
            disp = base_path.relative_to(REPO_ROOT)
        except ValueError:
            disp = base_path
        info(f"{Color.GREEN}Placed:{Color.RESET} {rel_path} -> {disp}")
        return True

    return False


def _classify_pullable(changed_files, conflict_files, provenance, manifest_files):
    """Determine which changed files can be auto-applied during pull.

    Returns (can_apply, cannot_apply) lists.
    """
    can_apply = []
    cannot_apply = []
    for fp in changed_files:
        prov = provenance.get(fp)
        manifest_entry = manifest_files.get(fp, {})
        manifest_components = manifest_entry.get("components")
        if fp in conflict_files:
            cannot_apply.append(fp)
        elif prov and not prov.has_overrides:
            can_apply.append(fp)
        elif prov and prov.has_overrides and manifest_components:
            local_components_unchanged = True
            for mc in manifest_components:
                source_path = REPO_ROOT / mc["source"]
                if source_path.exists():
                    current_hash = hashlib.sha256(source_path.read_bytes()).hexdigest()
                    if current_hash != mc["hash"]:
                        local_components_unchanged = False
                        break
                else:
                    local_components_unchanged = False
                    break
            if local_components_unchanged:
                can_apply.append(fp)
            else:
                cannot_apply.append(fp)
        else:
            cannot_apply.append(fp)
    return can_apply, cannot_apply


def _apply_pull_files(can_apply, provenance, remote_dir, local_dir, manifest_files):
    """Apply pulled files to local source. Returns (applied_count, pull_applied_dict)."""
    applied = 0
    pull_applied = {}
    for fp in can_apply:
        prov = provenance[fp]
        remote_file = remote_dir / fp

        if prov.has_overrides:
            manifest_entry = manifest_files.get(fp, {})
            manifest_comps = manifest_entry.get("components", [])
            remote_content = remote_file.read_bytes()
            deployed_content = local_dir / fp

            try:
                deployed_lines = deployed_content.read_text().splitlines(keepends=True)
                remote_lines = remote_content.decode().splitlines(keepends=True)
            except UnicodeDecodeError:
                info(f"{Color.YELLOW}Skipped:{Color.RESET} {fp} (binary composite)")
                continue

            updated_components = 0
            for mc in manifest_comps:
                source_path = REPO_ROOT / mc["source"]
                if not source_path.exists():
                    continue
                old_component = source_path.read_bytes()
                old_hash = hashlib.sha256(old_component).hexdigest()
                if old_hash != mc["hash"]:
                    continue

                if mc["mode"] == "base" and len(manifest_comps) == 2:
                    override_comp = [c for c in manifest_comps if c["mode"] != "base"][0]
                    override_source = REPO_ROOT / override_comp["source"]
                    if override_source.exists():
                        override_content = override_source.read_text()
                        override_mode = override_comp["mode"]
                        if override_mode == "prepend":
                            remote_text = remote_content.decode()
                            sep = override_content.rstrip() + "\n\n"
                            if remote_text.startswith(sep):
                                new_base = remote_text[len(sep):]
                                source_path.write_text(new_base)
                                updated_components += 1
                                try:
                                    src_rel = source_path.relative_to(REPO_ROOT)
                                except ValueError:
                                    src_rel = source_path
                                info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {src_rel} (base extracted)")
                                continue
                        elif override_mode == "append":
                            remote_text = remote_content.decode()
                            sep = "\n\n" + override_content
                            if remote_text.endswith(sep):
                                new_base = remote_text[:-len(sep)]
                                source_path.write_text(new_base)
                                updated_components += 1
                                try:
                                    src_rel = source_path.relative_to(REPO_ROOT)
                                except ValueError:
                                    src_rel = source_path
                                info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {src_rel} (base extracted)")
                                continue

                elif mc["mode"] in ("prepend", "append") and len(manifest_comps) == 2:
                    base_comp = [c for c in manifest_comps if c["mode"] == "base"][0]
                    base_source = REPO_ROOT / base_comp["source"]
                    if base_source.exists():
                        base_content = base_source.read_text()
                        remote_text = remote_content.decode()
                        if mc["mode"] == "prepend":
                            sep = "\n\n" + base_content
                            if remote_text.endswith(sep):
                                new_override = remote_text[:-len(sep)]
                                source_path.write_text(new_override)
                                updated_components += 1
                                try:
                                    src_rel = source_path.relative_to(REPO_ROOT)
                                except ValueError:
                                    src_rel = source_path
                                info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {src_rel} (override extracted)")
                                continue
                        elif mc["mode"] == "append":
                            sep = base_content.rstrip() + "\n\n"
                            if remote_text.startswith(sep):
                                new_override = remote_text[len(sep):]
                                source_path.write_text(new_override)
                                updated_components += 1
                                try:
                                    src_rel = source_path.relative_to(REPO_ROOT)
                                except ValueError:
                                    src_rel = source_path
                                info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {src_rel} (override extracted)")
                                continue

                elif mc["mode"] == "replace":
                    source_path.write_bytes(remote_content)
                    updated_components += 1
                    try:
                        src_rel = source_path.relative_to(REPO_ROOT)
                    except ValueError:
                        src_rel = source_path
                    info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {src_rel}")
                    continue

            if updated_components > 0:
                applied += 1
                pull_applied[fp] = str(prov.source_path)
            else:
                info(f"{Color.YELLOW}Skipped:{Color.RESET} {fp} (could not reconcile composite)")
        else:
            if not remote_file.exists():
                info(f"{Color.YELLOW}Skipped:{Color.RESET} {fp} (deleted on remote)")
                continue
            target_path = prov.source_path
            target_path.parent.mkdir(parents=True, exist_ok=True)
            target_path.write_bytes(remote_file.read_bytes())
            applied += 1
            pull_applied[fp] = str(prov.source_path)
            try:
                source_rel = prov.source_path.relative_to(REPO_ROOT)
            except ValueError:
                source_rel = prov.source_path
            info(f"{Color.GREEN}Applied:{Color.RESET} {fp} -> {source_rel}")

    return applied, pull_applied


def cmd_pull(args):
    """Sync changes FROM server back to local."""
    bundle_name = args.name

    # Load destination
    dest = load_destination_for_bundle(bundle_name)
    if not dest:
        die(
            f"No destination configured for bundle '{bundle_name}'.\n"
            f"Create bundles/{bundle_name}/destination.private with:\n"
            f"  target = \"user@host:~\"\n"
            f"  ssh_opts = \"\"  # optional"
        )

    # -y/--yes implies --apply
    do_apply = args.apply or args.yes

    # Clean repo check: block apply, warn in preview
    repo_errors = _check_repos_clean()
    if repo_errors:
        if do_apply:
            print(f"\n{Color.YELLOW}Cannot apply: uncommitted changes detected.{Color.RESET}")
            for err in repo_errors:
                print(f"\n{err}")
            print(f"\nCommit or stash your changes, then run pull again.")
            sys.exit(1)
        else:
            print(f"\n{Color.YELLOW}Warning: uncommitted changes detected — preview may be incomplete.{Color.RESET}")
            for err in repo_errors:
                print(f"\n{err}")

    print(f"\nPulling from: {dest.target}")
    print(f"Bundle: {bundle_name}")

    # Build local package (same as deploy)
    resolver = BundleResolver()
    config = resolver.resolve(bundle_name)
    file_resolver = FileResolver()
    files = file_resolver.resolve_bundle(config)

    with tempfile.TemporaryDirectory() as temp_dir:
        # Build local package
        local_dir = Path(temp_dir) / "local"
        local_dir.mkdir()

        builder = PackageBuilder(bundle_name, config)
        for resolved in files:
            builder._copy_file(resolved, local_dir)
        builder._copy_additions(local_dir)

        # Build provenance map
        provenance = build_provenance_map(bundle_name, files, builder.override_manager)

        file_paths = sorted(provenance.keys())

        # Pull from remote using include/exclude patterns for full directory scanning
        remote_dir = Path(temp_dir) / "remote"
        remote_dir.mkdir()

        deployer = Deployer(dest)
        multiplexing = deployer.start_multiplexing()
        if multiplexing:
            print("  SSH connection established.")
        print("\nPulling remote files...")
        all_includes = list(config.files_include) + list(config.runtime_include)
        all_excludes = list(config.files_exclude) + list(config.runtime_exclude)

        # Also include paths from additions (e.g., .hgrc, .cargo/config.toml)
        # that aren't covered by the directory-based include patterns
        for fp in file_paths:
            prov = provenance.get(fp)
            if prov and prov.source_type == "addition":
                if not any(glob_match(p, fp) for p in all_includes):
                    # Add the specific file path
                    all_includes.append(fp)

        if not deployer.pull_with_patterns(remote_dir, all_includes, all_excludes):
            die("Failed to pull from remote")

        # Three-way comparison using manifest
        manifest = read_manifest(bundle_name)
        manifest_files_set = set(manifest.get("files", {}).keys()) if manifest else set()

        # Include manifest paths so we detect files removed from local package
        all_paths = sorted(set(file_paths) | manifest_files_set)

        # Detect deleted files (in provenance but not on remote)
        deleted_files = []
        for fp in file_paths:
            local_file = local_dir / fp
            remote_file = remote_dir / fp
            if not remote_file.exists() and local_file.exists():
                deleted_files.append(fp)

        # Classify changed files by direction
        classifications = classify_changes(package_dir=local_dir, remote_dir=remote_dir, file_paths=all_paths, manifest=manifest)

        remote_only_files = [f for f, c in classifications.items() if c == "remote_only"]
        local_only_files = [f for f, c in classifications.items() if c == "local_only"]
        conflict_files = [f for f, c in classifications.items() if c == "both"]
        no_manifest_files = [f for f, c in classifications.items() if c == "no_manifest"]

        # Apply pull_ignore early to filter all lists
        pull_ignore = config.pull_ignore
        if pull_ignore:
            _ign = lambda fp: any(glob_match(p, fp) for p in pull_ignore)
            remote_only_files = [f for f in remote_only_files if not _ign(f)]
            local_only_files = [f for f in local_only_files if not _ign(f)]
            conflict_files = [f for f in conflict_files if not _ign(f)]
            no_manifest_files = [f for f in no_manifest_files if not _ign(f)]
            deleted_files = [f for f in deleted_files if not _ign(f)]

        # Compute line stats for files we'll display
        line_stats = {}
        for fp in remote_only_files + conflict_files + no_manifest_files:
            local_file = local_dir / fp
            remote_file = remote_dir / fp
            if not local_file.exists() or not remote_file.exists():
                continue
            try:
                local_lines = local_file.read_text().splitlines()
                remote_lines = remote_file.read_text().splitlines()
                diff = list(difflib.unified_diff(local_lines, remote_lines, n=0))
                ins = sum(1 for l in diff if l.startswith("+") and not l.startswith("+++"))
                dels = sum(1 for l in diff if l.startswith("-") and not l.startswith("---"))
                line_stats[fp] = (ins, dels)
            except UnicodeDecodeError:
                pass

        # Only files with deployment history are candidates for pull
        changed_files = remote_only_files + conflict_files

        # Detect new remote files (in pulled directories but not in provenance or manifest)
        new_remote_files = []
        for remote_file in sorted(remote_dir.rglob("*")):
            if not remote_file.is_file():
                continue
            rel = str(remote_file.relative_to(remote_dir))
            if rel in provenance or rel in classifications:
                continue
            if not any(glob_match(p, rel) for p in config.files_include):
                continue
            if any(glob_match(ex, rel) for ex in config.files_exclude):
                continue
            if any(glob_match(p, rel) for p in pull_ignore):
                continue
            new_remote_files.append(rel)

        if not changed_files and not local_only_files and not new_remote_files and not deleted_files:
            print("\nNo changes detected. Remote matches local.")
            log_operation(bundle_name, "pull", "no changes")
            return

        manifest_files = manifest.get("files", {}) if manifest else {}
        if manifest:
            deployed_at = manifest.get("deployed_at", "unknown")
            print(f"  Last deploy: {Color.DIM}{deployed_at}{Color.RESET}")

        # Classify deleted files using manifest
        actually_deleted = []  # was deployed, then removed on remote
        not_yet_deployed = []  # never deployed
        for fp in deleted_files:
            if fp in manifest_files:
                actually_deleted.append(fp)
            else:
                not_yet_deployed.append(fp)

        # --- Determine which files can be auto-applied ---
        can_apply, cannot_apply = _classify_pullable(changed_files, conflict_files, provenance, manifest_files)

        # --- Display remote-only changes (pullable) ---
        if remote_only_files:
            print(f"\n{len(remote_only_files)} remote-only change(s):")
            for fp in remote_only_files:
                prov = provenance.get(fp)
                stats = line_stats.get(fp)
                if stats:
                    stat_str = f"  {Color.GREEN}+{stats[0]}{Color.RESET} {Color.MAGENTA}-{stats[1]}{Color.RESET}"
                if prov and not prov.has_overrides:
                    try:
                        source_rel = prov.source_path.relative_to(REPO_ROOT)
                    except ValueError:
                        source_rel = prov.source_path
                    label = f" -> {Color.DIM}{source_rel}{Color.RESET}"
                elif fp in can_apply:
                    label = f" {Color.DIM}(composite, reconcilable){Color.RESET}"
                else:
                    label = f" {Color.DIM}(composite, manual only){Color.RESET}"
                info(f"{Color.YELLOW}M{Color.RESET} {fp}{label}{stat_str}")

        # --- Display local-only changes (informational) ---
        if local_only_files:
            print(f"\n{len(local_only_files)} local-only change(s) (deploy to push):")
            for fp in local_only_files:
                info(f"{Color.DIM}L{Color.RESET} {fp}")

        # --- Display conflicts ---
        if conflict_files:
            print(f"\n{Color.YELLOW}{len(conflict_files)} conflict(s) — changed on both sides:{Color.RESET}")
            for fp in conflict_files:
                stats = line_stats.get(fp)
                stat_str = ""
                if stats:
                    stat_str = f"  {Color.GREEN}+{stats[0]}{Color.RESET} {Color.MAGENTA}-{stats[1]}{Color.RESET}"
                info(f"{Color.YELLOW}C{Color.RESET} {fp}{stat_str}")

        # --- Display no-manifest files ---
        if no_manifest_files:
            print(f"\n{len(no_manifest_files)} changed file(s) (no manifest — unknown direction):")
            for fp in no_manifest_files:
                stats = line_stats.get(fp)
                stat_str = ""
                if stats:
                    stat_str = f"  {Color.GREEN}+{stats[0]}{Color.RESET} {Color.MAGENTA}-{stats[1]}{Color.RESET}"
                info(f"{Color.YELLOW}?{Color.RESET} {fp}{stat_str}")

        # --- Display new files ---
        if new_remote_files:
            print(f"\n{len(new_remote_files)} new file(s) on remote:")
            for fp in new_remote_files:
                info(f"{Color.GREEN}A{Color.RESET} {fp}")

        # --- Display deleted/not-deployed files ---
        if actually_deleted:
            print(f"\n{len(actually_deleted)} deleted file(s) on remote:")
            for fp in actually_deleted:
                prov = provenance.get(fp)
                if prov:
                    try:
                        source_rel = prov.source_path.relative_to(REPO_ROOT)
                    except ValueError:
                        source_rel = prov.source_path
                    target = f" {Color.DIM}({source_rel}){Color.RESET}"
                else:
                    target = ""
                info(f"{Color.MAGENTA}D{Color.RESET} {fp}{target}")

        if not_yet_deployed:
            print(f"\n{len(not_yet_deployed)} not yet deployed:")
            for fp in not_yet_deployed:
                info(f"{Color.DIM}-{Color.RESET} {fp}")

        # --- Show diffs if verbose ---
        if args.verbose:
            for fp in changed_files:
                local_file = local_dir / fp
                remote_file = remote_dir / fp
                print(f"\n{'─' * 60}")
                print(f"{Color.BOLD}{fp}{Color.RESET} {Color.DIM}(changed){Color.RESET}")
                print(f"{'─' * 60}")
                try:
                    local_lines = local_file.read_text().splitlines(keepends=True)
                    remote_lines = remote_file.read_text().splitlines(keepends=True)
                    diff = difflib.unified_diff(
                        local_lines, remote_lines,
                        fromfile=f"local/{fp}",
                        tofile=f"remote/{fp}",
                    )
                    diff_text = "".join(diff)
                    if diff_text:
                        for line in diff_text.splitlines():
                            if line.startswith("+") and not line.startswith("+++"):
                                print(f"  {Color.GREEN}{line}{Color.RESET}")
                            elif line.startswith("-") and not line.startswith("---"):
                                print(f"  {Color.MAGENTA}{line}{Color.RESET}")
                            else:
                                print(f"  {line}")
                    else:
                        print(f"  {Color.DIM}(no text diff available){Color.RESET}")
                except UnicodeDecodeError:
                    print(f"  {Color.DIM}(binary file){Color.RESET}")

            for fp in new_remote_files:
                remote_file = remote_dir / fp
                print(f"\n{'─' * 60}")
                print(f"{Color.BOLD}{fp}{Color.RESET} {Color.DIM}(new){Color.RESET}")
                print(f"{'─' * 60}")
                try:
                    for line in remote_file.read_text().splitlines():
                        print(f"  {Color.GREEN}+{line}{Color.RESET}")
                except UnicodeDecodeError:
                    print(f"  {Color.DIM}(binary file){Color.RESET}")

        if not do_apply:
            hints = []
            if not args.verbose:
                hints.append(f"Run with {Color.CYAN}-v{Color.RESET} to see diffs.")
            hints.append(f"Run with {Color.CYAN}--apply{Color.RESET} to write changes back to source files.")
            print()
            for h in hints:
                print(h)
            # Log preview
            found = []
            if changed_files:
                found.append(f"{len(changed_files)} modified")
            if new_remote_files:
                found.append(f"{len(new_remote_files)} new")
            if actually_deleted:
                found.append(f"{len(actually_deleted)} deleted")
            if found:
                log_operation(bundle_name, "pull", f"preview: {', '.join(found)}")
            return

        # --- Apply changed files ---
        applied = 0
        pull_applied = {}   # {deployed_path: source_path}
        pull_placed = {}    # {deployed_path: placement}
        if changed_files:
            if cannot_apply:
                print(f"\n{Color.YELLOW}Skipping {len(cannot_apply)} composite file(s) (manual apply only):{Color.RESET}")
                for fp in cannot_apply:
                    info(fp)

            if can_apply:
                if not args.yes:
                    print(f"\n{len(can_apply)} changed file(s) to write back:")
                    for fp in can_apply:
                        prov = provenance[fp]
                        try:
                            source_rel = prov.source_path.relative_to(REPO_ROOT)
                        except ValueError:
                            source_rel = prov.source_path
                        info(f"{fp} -> {source_rel}")

                    response = input("\nApply changed files? [y/N]: ").strip().lower()
                    if response != "y":
                        if not new_remote_files:
                            print("Aborted.")
                            return
                        print("Skipped changed files.")
                        can_apply = []

                applied, pull_applied = _apply_pull_files(can_apply, provenance, remote_dir, local_dir, manifest_files)

        # --- Place new files ---
        placed = 0
        if new_remote_files:
            if args.yes:
                print(f"\n{Color.YELLOW}Skipping {len(new_remote_files)} new file(s) — interactive placement required, run without -y{Color.RESET}")
            else:
                print(f"\nPlacing {len(new_remote_files)} new file(s):")
                for fp in new_remote_files:
                    remote_file = remote_dir / fp
                    content = remote_file.read_bytes()
                    mode = remote_file.stat().st_mode
                    placement = _prompt_new_file_placement(fp, bundle_name)
                    if placement == "skip":
                        continue
                    if _place_new_file(fp, content, placement, bundle_name, mode=mode):
                        placed += 1
                        pull_placed[fp] = placement

        # Summary
        parts = []
        if applied:
            parts.append(f"{applied} changed file(s) applied")
        if placed:
            parts.append(f"{placed} new file(s) placed")
        if cannot_apply:
            parts.append(f"{len(cannot_apply)} composite file(s) skipped")
        if parts:
            summary = '. '.join(parts)
            print(f"\n{summary}.")
            log_operation(bundle_name, "pull", f"apply: {summary}")

            # Write pull manifest
            if pull_applied or pull_placed:
                write_pull_manifest(bundle_name, pull_applied, pull_placed)

            # Update deploy manifest to reflect new local state
            # This prevents false conflicts on the next deploy/pull
            if pull_applied or pull_placed:
                rebuild_dir = Path(temp_dir) / "rebuild"
                rebuild_dir.mkdir()
                rebuild_builder = PackageBuilder(bundle_name, config)
                rebuild_files = file_resolver.resolve_bundle(config)
                for resolved in rebuild_files:
                    rebuild_builder._copy_file(resolved, rebuild_dir)
                rebuild_builder._copy_additions(rebuild_dir)
                new_manifest = build_manifest(bundle_name, rebuild_files, rebuild_builder.override_manager, rebuild_dir)
                write_manifest(bundle_name, new_manifest)
                print(f"  Manifest updated.")


def cmd_sync(args):
    """Bidirectional sync: pull remote changes, then deploy local changes."""
    bundle_name = args.name

    dest = load_destination_for_bundle(bundle_name)
    if not dest:
        die(
            f"No destination configured for bundle '{bundle_name}'.\n"
            f"Create bundles/{bundle_name}/destination.private with:\n"
            f"  target = \"user@host:~\"\n"
            f"  ssh_opts = \"\"  # optional"
        )

    do_apply = args.apply or args.yes

    repo_errors = _check_repos_clean()
    if repo_errors:
        if do_apply:
            print(f"\n{Color.YELLOW}Cannot sync: uncommitted changes detected.{Color.RESET}")
            for err in repo_errors:
                print(f"\n{err}")
            print(f"\nCommit or stash your changes, then run sync again.")
            sys.exit(1)
        else:
            print(f"\n{Color.YELLOW}Warning: uncommitted changes detected — preview may be incomplete.{Color.RESET}")
            for err in repo_errors:
                print(f"\n{err}")

    print(f"\nSyncing bundle: {bundle_name}")
    print(f"Destination: {dest.target}")

    # Build local package
    resolver = BundleResolver()
    config = resolver.resolve(bundle_name)
    file_resolver = FileResolver()
    files = file_resolver.resolve_bundle(config)

    with tempfile.TemporaryDirectory() as temp_dir:
        local_dir = Path(temp_dir) / "local"
        local_dir.mkdir()

        builder = PackageBuilder(bundle_name, config)
        for resolved in files:
            builder._copy_file(resolved, local_dir)
        builder._copy_additions(local_dir)

        package_dir = local_dir

        provenance = build_provenance_map(bundle_name, files, builder.override_manager)
        file_paths = sorted(provenance.keys())

        # Pull remote files
        remote_dir = Path(temp_dir) / "remote"
        remote_dir.mkdir()

        deployer = Deployer(dest)
        multiplexing = deployer.start_multiplexing()
        if multiplexing:
            print("  SSH connection established.")

        all_includes = list(config.files_include) + list(config.runtime_include)
        all_excludes = list(config.files_exclude) + list(config.runtime_exclude)
        for fp in file_paths:
            prov = provenance.get(fp)
            if prov and prov.source_type == "addition":
                if not any(glob_match(p, fp) for p in all_includes):
                    all_includes.append(fp)

        print("\nFetching remote state...")
        if not deployer.pull_with_patterns(remote_dir, all_includes, all_excludes):
            die("Failed to connect to remote")

        # Three-way classification
        manifest = read_manifest(bundle_name)
        manifest_files = manifest.get("files", {}) if manifest else {}
        manifest_files_set = set(manifest_files.keys())
        all_paths = sorted(set(file_paths) | manifest_files_set)

        classifications = classify_changes(
            package_dir=local_dir, remote_dir=remote_dir,
            file_paths=all_paths, manifest=manifest,
        )

        remote_only_files = [f for f, c in classifications.items() if c == "remote_only"]
        local_only_files = [f for f, c in classifications.items() if c == "local_only"]
        conflict_files = [f for f, c in classifications.items() if c == "both"]
        no_manifest_files = [f for f, c in classifications.items() if c == "no_manifest"]

        pull_ignore = config.pull_ignore
        if pull_ignore:
            _ign = lambda fp: any(glob_match(p, fp) for p in pull_ignore)
            remote_only_files = [f for f in remote_only_files if not _ign(f)]
            local_only_files = [f for f in local_only_files if not _ign(f)]
            conflict_files = [f for f in conflict_files if not _ign(f)]
            no_manifest_files = [f for f in no_manifest_files if not _ign(f)]

        # Detect deleted files
        deleted_files = []
        for fp in file_paths:
            local_file = local_dir / fp
            remote_file = remote_dir / fp
            if not remote_file.exists() and local_file.exists():
                deleted_files.append(fp)
        if pull_ignore:
            deleted_files = [f for f in deleted_files if not _ign(f)]

        actually_deleted = [fp for fp in deleted_files if fp in manifest_files]

        # Detect new remote files
        new_remote_files = []
        for remote_file in sorted(remote_dir.rglob("*")):
            if not remote_file.is_file():
                continue
            rel = str(remote_file.relative_to(remote_dir))
            if rel in provenance or rel in classifications:
                continue
            if not any(glob_match(p, rel) for p in config.files_include):
                continue
            if any(glob_match(ex, rel) for ex in config.files_exclude):
                continue
            if pull_ignore and any(glob_match(p, rel) for p in pull_ignore):
                continue
            new_remote_files.append(rel)

        # Classify pullable files
        changed_files = remote_only_files + conflict_files
        can_pull, cannot_pull = _classify_pullable(changed_files, conflict_files, provenance, manifest_files)

        # Compute line stats for display
        line_stats = {}
        for fp in remote_only_files + local_only_files + conflict_files:
            local_file = local_dir / fp
            remote_file = remote_dir / fp
            if not local_file.exists() or not remote_file.exists():
                continue
            try:
                local_lines = local_file.read_text().splitlines()
                remote_lines = remote_file.read_text().splitlines()
                diff = list(difflib.unified_diff(local_lines, remote_lines, n=0))
                ins = sum(1 for l in diff if l.startswith("+") and not l.startswith("+++"))
                dels = sum(1 for l in diff if l.startswith("-") and not l.startswith("---"))
                line_stats[fp] = (ins, dels)
            except UnicodeDecodeError:
                pass

        # Count unchanged
        unchanged_count = sum(1 for c in classifications.values() if c == "unchanged")

        # --- Display sync summary ---
        if not remote_only_files and not local_only_files and not conflict_files and not new_remote_files and not actually_deleted:
            print("\nAlready in sync.")
            deployer.stop_multiplexing()
            return

        if manifest:
            deployed_at = manifest.get("deployed_at", "unknown")
            print(f"  Last deploy: {Color.DIM}{deployed_at}{Color.RESET}")

        print(f"\n{Color.CYAN}Sync summary:{Color.RESET}")

        if can_pull:
            print(f"\n  {len(can_pull)} file(s) to pull (remote -> local):")
            for fp in can_pull:
                stats = line_stats.get(fp)
                stat_str = f"  {Color.GREEN}+{stats[0]}{Color.RESET} {Color.RED}-{stats[1]}{Color.RESET}" if stats else ""
                prov = provenance.get(fp)
                dest_str = ""
                if prov:
                    try:
                        dest_str = f" -> {prov.source_path.relative_to(REPO_ROOT)}"
                    except ValueError:
                        dest_str = f" -> {prov.source_path}"
                info(f"  {Color.CYAN}<-{Color.RESET} {fp}{dest_str}{stat_str}")

        if local_only_files:
            print(f"\n  {len(local_only_files)} file(s) to deploy (local -> remote):")
            for fp in local_only_files:
                stats = line_stats.get(fp)
                stat_str = f"  {Color.GREEN}+{stats[0]}{Color.RESET} {Color.RED}-{stats[1]}{Color.RESET}" if stats else ""
                info(f"  {Color.GREEN}->{Color.RESET} {fp}{stat_str}")

        if conflict_files:
            print(f"\n  {Color.YELLOW}{len(conflict_files)} conflict(s) — resolve manually (pull or deploy --force):{Color.RESET}")
            for fp in conflict_files:
                stats = line_stats.get(fp)
                stat_str = f"  +{stats[0]} -{stats[1]}" if stats else ""
                info(f"  {Color.YELLOW}!!{Color.RESET} {fp}{stat_str}")

        if cannot_pull:
            non_conflict = [fp for fp in cannot_pull if fp not in conflict_files]
            if non_conflict:
                print(f"\n  {Color.YELLOW}{len(non_conflict)} composite file(s) — cannot auto-pull:{Color.RESET}")
                for fp in non_conflict:
                    info(f"  {Color.YELLOW}??{Color.RESET} {fp}")

        if new_remote_files:
            print(f"\n  {len(new_remote_files)} new file(s) on remote:")
            for fp in new_remote_files:
                info(f"  {Color.CYAN}+ {Color.RESET} {fp}")

        if actually_deleted:
            print(f"\n  {len(actually_deleted)} deleted file(s) on remote:")
            for fp in actually_deleted:
                info(f"  {Color.RED}D {Color.RESET} {fp}")

        if unchanged_count:
            print(f"\n  {unchanged_count} file(s) unchanged")

        if args.verbose:
            for fp in can_pull + local_only_files + conflict_files:
                local_file = local_dir / fp
                remote_file = remote_dir / fp
                if local_file.exists() and remote_file.exists():
                    try:
                        local_lines = local_file.read_text().splitlines()
                        remote_lines = remote_file.read_text().splitlines()
                        diff = difflib.unified_diff(local_lines, remote_lines, fromfile=f"local/{fp}", tofile=f"remote/{fp}", lineterm="")
                        diff_lines = list(diff)
                        if diff_lines:
                            print(f"\n  --- {fp} ---")
                            for line in diff_lines[:30]:
                                if line.startswith("+") and not line.startswith("+++"):
                                    print(f"  {Color.GREEN}{line}{Color.RESET}")
                                elif line.startswith("-") and not line.startswith("---"):
                                    print(f"  {Color.RED}{line}{Color.RESET}")
                                else:
                                    print(f"  {line}")
                            if len(diff_lines) > 30:
                                print(f"  ... {len(diff_lines) - 30} more lines")
                    except UnicodeDecodeError:
                        pass

        # --- Dry-run: stop here ---
        if not do_apply:
            hints = []
            if not args.verbose and (can_pull or local_only_files or conflict_files):
                hints.append(f"Run with {Color.CYAN}-v{Color.RESET} to see diffs.")
            hints.append(f"Run with {Color.CYAN}--apply{Color.RESET} to execute sync.")
            if hints:
                print(f"\n{'  '.join(hints)}")
            log_operation(bundle_name, "sync", "preview")
            deployer.stop_multiplexing()
            return

        # --- Confirmation ---
        pull_count = len(can_pull)
        deploy_count = len(local_only_files)
        if not args.yes:
            prompt_parts = []
            if pull_count:
                prompt_parts.append(f"pull {pull_count}")
            if deploy_count:
                prompt_parts.append(f"deploy {deploy_count}")
            prompt = " and ".join(prompt_parts) + " file(s)"
            response = input(f"\n{prompt}? [y/N]: ").strip().lower()
            if response != "y":
                print("Aborted.")
                deployer.stop_multiplexing()
                return

        # --- Phase 1: Pull remote-only changes ---
        pull_applied = {}
        if can_pull:
            print(f"\nPulling {pull_count} file(s)...")
            _, pull_applied = _apply_pull_files(can_pull, provenance, remote_dir, local_dir, manifest_files)

        # --- Phase 2: Rebuild package after pull ---
        if pull_applied:
            rebuild_dir = Path(temp_dir) / "rebuild"
            rebuild_dir.mkdir()
            rebuild_builder = PackageBuilder(bundle_name, config)
            rebuild_files = file_resolver.resolve_bundle(config)
            for resolved in rebuild_files:
                rebuild_builder._copy_file(resolved, rebuild_dir)
            rebuild_builder._copy_additions(rebuild_dir)
            package_dir = rebuild_dir
            files = rebuild_files
            builder = rebuild_builder

        # --- Phase 3: Deploy local-only changes ---
        deployed_count = 0
        if deploy_count:
            # Exclude remote-only, conflicts, and no-manifest from deploy
            deploy_excludes = remote_only_files + conflict_files + no_manifest_files
            changes, _ = deployer.preview(package_dir, extra_excludes=deploy_excludes)
            if changes:
                print(f"\nBacking up remote files...")
                backup_ts = backup_remote_files(deployer, changes)
                if backup_ts:
                    print(f"  Backed up to ~/{BACKUP_REMOTE_DIR}/{backup_ts}/")
                else:
                    print(f"  {Color.YELLOW}Backup failed. Skipping deploy.{Color.RESET}")
                    changes = []

            if changes:
                print(f"\nDeploying {len(changes)} file(s)...")
                success, synced = deployer.deploy(package_dir, extra_excludes=deploy_excludes)
                if success:
                    deployed_count = len(synced)
                else:
                    print(f"  {Color.YELLOW}Deploy failed.{Color.RESET}")

        # --- Phase 4: Update manifest ---
        new_manifest = build_manifest(bundle_name, files, builder.override_manager, package_dir)
        write_manifest(bundle_name, new_manifest)

        if pull_applied:
            write_pull_manifest(bundle_name, pull_applied, {})

        # --- Summary ---
        parts = []
        if pull_applied:
            parts.append(f"{len(pull_applied)} pulled")
        if deployed_count:
            parts.append(f"{deployed_count} deployed")
        if conflict_files:
            parts.append(f"{len(conflict_files)} conflict(s) skipped")
        if parts:
            print(f"\nSync complete: {', '.join(parts)}.")
        else:
            print("\nSync complete: no changes applied.")
        log_operation(bundle_name, "sync", ", ".join(parts) if parts else "no changes")

        deployer.stop_multiplexing()


# ============================================================================
# Main
# ============================================================================


def main():
    parser = argparse.ArgumentParser(
        description="Bundle management for dotfiles deployment",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # list
    p_list = subparsers.add_parser("list", help="List available bundles")
    p_list.set_defaults(func=cmd_list)

    # show
    p_show = subparsers.add_parser("show", help="Show bundle contents")
    p_show.add_argument("name", help="Bundle name")
    p_show.add_argument("-v", "--verbose", action="store_true", help="Show all files, not just first 15")
    p_show.set_defaults(func=cmd_show)

    # build
    p_build = subparsers.add_parser("build", help="Build bundle tarball")
    p_build.add_argument("name", help="Bundle name")
    p_build.add_argument("-o", "--output", help="Output path")
    p_build.set_defaults(func=cmd_build)

    # deploy
    p_deploy = subparsers.add_parser("deploy", help="Build and deploy")
    p_deploy.add_argument("name", help="Bundle name")
    p_deploy.add_argument("-v", "--verbose", action="store_true", help="Show all files, not just first 20")
    p_deploy.add_argument("--apply", action="store_true", help="Deploy to destination (default: preview only)")
    p_deploy.add_argument("-y", "--yes", action="store_true", help="Deploy without confirmation (implies --apply)")
    p_deploy.add_argument("--force", action="store_true", help="Skip remote change check")
    p_deploy.set_defaults(func=cmd_deploy)

    # pull
    p_pull = subparsers.add_parser("pull", help="Sync changes from remote")
    p_pull.add_argument("name", help="Bundle name")
    p_pull.add_argument("-v", "--verbose", action="store_true", help="Show diffs for changed files")
    p_pull.add_argument("--apply", action="store_true", help="Write changes back to source files (default: show only)")
    p_pull.add_argument("-y", "--yes", action="store_true", help="Apply without confirmation (implies --apply)")
    p_pull.set_defaults(func=cmd_pull)

    # sync
    p_sync = subparsers.add_parser("sync", help="Bidirectional sync (pull + deploy)")
    p_sync.add_argument("name", help="Bundle name")
    p_sync.add_argument("-v", "--verbose", action="store_true", help="Show diffs for changed files")
    p_sync.add_argument("--apply", action="store_true", help="Execute sync (default: preview only)")
    p_sync.add_argument("-y", "--yes", action="store_true", help="Sync without confirmation (implies --apply)")
    p_sync.set_defaults(func=cmd_sync)

    args = parser.parse_args()

    try:
        args.func(args)
    except KeyboardInterrupt:
        print("\nAborted.", file=sys.stderr)
        sys.exit(130)


if __name__ == "__main__":
    main()
