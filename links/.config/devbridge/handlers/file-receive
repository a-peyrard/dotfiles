#!/usr/bin/env python3
"""devbridge handler: receive a base64-encoded file and write to disk.

Args (JSON stdin): {"filename": "name.png", "data": "<base64>", "dest": "/tmp"}
dest defaults to /tmp if not provided.
"""

import base64
import json
import os
import sys


def main():
    args = json.load(sys.stdin)

    filename = args.get("filename", "")
    data_b64 = args.get("data", "")
    dest_dir = args.get("dest", "/tmp")

    if not filename:
        print("Missing 'filename' argument", file=sys.stderr)
        sys.exit(1)
    if not data_b64:
        print("Missing 'data' argument", file=sys.stderr)
        sys.exit(1)

    # Sanitize filename — no path traversal
    filename = os.path.basename(filename)
    dest_path = os.path.join(dest_dir, filename)

    data = base64.b64decode(data_b64)
    with open(dest_path, "wb") as f:
        f.write(data)

    print(dest_path)


if __name__ == "__main__":
    main()
