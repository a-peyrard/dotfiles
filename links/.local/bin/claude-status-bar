#!/usr/bin/env python3
# /// script
# requires-python = ">=3.9"
# ///
"""
Operator-centric Claude agent status for tmux status bar.

Per-tab: colored ● dot next to window name (highest-priority agent state).
Right-side: reverse-video badge counters per state category.

States (priority order):
  Red ●    = agent needs input (permission prompt or elicitation dialog)
  Orange ● = agent finished work, you haven't looked yet (unread)
  Green ●  = agent is actively working
  (no dot) = agent is idle and read

Classification matches claude-sessions-tui:
  - "working" → WORKING (green)
  - "waiting" + current_tool in {permission_prompt, elicitation_dialog} → NEEDS_INPUT (red)
  - everything else → IDLE (orange if unread, no dot if read)

Unread tracking: detects WORKING→IDLE transitions, shares state with the TUI
via ~/.cache/claude-sessions/unread.json. Auto-read when viewing a window.

State files from tmux-statusline plugin hooks (read-only dependency).

Integration:
  - Sets @claude per-window (read by window-status-format via #{E:#{@claude}})
  - Stdout = right-side counters (read by status-right via #())
"""

import json
import os
import re
import subprocess
import tempfile
from collections import defaultdict
from pathlib import Path

STATE_BASE_DIR = Path.home() / ".claude-sessions" / "state"
CACHE_DIR = Path.home() / ".cache" / "claude-sessions"
UNREAD_FILE = CACHE_DIR / "unread.json"
PREV_STATE_FILE = CACHE_DIR / "statusbar-prev.json"

GREEN = "#88c088"
ORANGE = "#d4a060"
RED = "#c07088"
GREY = "#a09880"

PRIORITY = {"green": 0, "orange": 1, "red": 2}
COLOR_MAP = {"green": GREEN, "orange": ORANGE, "red": RED, "grey": GREY}

NEEDS_INPUT_TOOLS = {"permission_prompt", "elicitation_dialog"}


def get_tmux_info():
    try:
        result = subprocess.run(
            [
                "tmux", "display-message", "-p",
                "#{session_name}\t#{pid}\t#{window_index}\t#{session_group}",
            ],
            capture_output=True, text=True, check=True, timeout=2,
        )
        parts = result.stdout.strip().split("\t")
        group = parts[3] if len(parts) > 3 and parts[3] else None
        return parts[0], int(parts[1]), int(parts[2]), group
    except Exception:
        return None, None, None, None


def get_session_group_members(session_group):
    if not session_group:
        return set()
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}\t#{session_group}"],
            capture_output=True, text=True, check=True, timeout=2,
        )
        return {
            parts[0]
            for line in result.stdout.strip().split("\n")
            if line
            for parts in [line.split("\t")]
            if len(parts) >= 2 and parts[1] == session_group
        }
    except Exception:
        return set()


def get_live_panes():
    try:
        result = subprocess.run(
            [
                "tmux", "list-panes", "-a", "-F",
                "#{pane_id}\t#{window_index}\t#{session_name}:#{window_index}.#{pane_index}",
            ],
            capture_output=True, text=True, check=True, timeout=2,
        )
        live = set()
        pane_to_window = {}
        pane_to_target = {}
        for line in result.stdout.strip().split("\n"):
            if not line:
                continue
            parts = line.split("\t")
            if len(parts) >= 3:
                pane_id, win_idx, target = parts[0], parts[1], parts[2]
                live.add(pane_id)
                try:
                    pane_to_window[pane_id] = int(win_idx)
                except ValueError:
                    pass
                pane_to_target[pane_id] = target
        return live, pane_to_window, pane_to_target
    except Exception:
        return set(), {}, {}


def get_all_window_indices():
    try:
        result = subprocess.run(
            ["tmux", "list-windows", "-F", "#{window_index}"],
            capture_output=True, text=True, check=True, timeout=2,
        )
        return {int(idx) for idx in result.stdout.strip().split("\n") if idx}
    except Exception:
        return set()


def classify_agent(status, current_tool):
    if status == "working":
        return "working"
    if status == "waiting" and current_tool in NEEDS_INPUT_TOOLS:
        return "needs_input"
    return "idle"


def load_json(path):
    try:
        return json.loads(path.read_text())
    except (json.JSONDecodeError, OSError):
        return None


def save_json(path, data):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    tmp = f"{path}.tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        json.dump(data, f)
    os.replace(tmp, str(path))


def set_window_options(window_states, all_windows):
    temp_path = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".conf", delete=False
        ) as f:
            for idx in all_windows:
                if idx in window_states:
                    color = COLOR_MAP[window_states[idx]]
                    val = f" #[fg={color}]●#[default]"
                    escaped = (
                        val.replace("\\", "\\\\")
                        .replace('"', '\\"')
                        .replace("$", "\\$")
                        .replace("`", "\\`")
                    )
                    f.write(f'set-window-option -t :{idx} @claude "{escaped}"\n')
                else:
                    f.write(f'set-window-option -t :{idx} @claude ""\n')
            temp_path = f.name

        subprocess.run(
            ["tmux", "source-file", temp_path],
            capture_output=True, check=False, timeout=2,
        )
    except Exception:
        pass
    finally:
        if temp_path:
            try:
                os.unlink(temp_path)
            except OSError:
                pass


def format_counters(counts):
    parts = []
    for state in ["red", "orange", "green", "grey"]:
        n = counts.get(state, 0)
        if n > 0:
            color = COLOR_MAP[state]
            parts.append(f"#[fg=#1a1a1a,bg={color},bold] {n} #[default]")
    return " ".join(parts)


def main():
    session_name, tmux_pid, active_window, session_group = get_tmux_info()
    if session_name is None or tmux_pid is None:
        return

    group_sessions = get_session_group_members(session_group)
    group_sessions.add(session_name)

    pid_dir = STATE_BASE_DIR / str(tmux_pid)
    live_panes, pane_to_window, pane_to_target = get_live_panes()
    all_windows = get_all_window_indices()

    # Collect state files, dedup by pane_id (keep newest)
    pane_latest = {}
    if pid_dir.exists():
        for state_file in pid_dir.glob("*.json"):
            try:
                state = json.loads(state_file.read_text())
                mtime = state_file.stat().st_mtime
            except (json.JSONDecodeError, OSError):
                continue

            if state.get("tmux_session") not in group_sessions:
                continue

            pane_id = state.get("pane_id")
            if pane_id not in live_panes or not re.match(r"^%\d+$", pane_id):
                continue

            if pane_id not in pane_latest or mtime > pane_latest[pane_id][1]:
                pane_latest[pane_id] = (state, mtime)

    # Load previous states and unread set
    prev_states = load_json(PREV_STATE_FILE) or {}
    unread_targets = set(load_json(UNREAD_FILE) or [])
    new_prev_states = {}
    unread_changed = False

    # Classify each agent and detect transitions
    agents = {}
    for pane_id, (state, _) in pane_latest.items():
        status = state.get("status", "")
        current_tool = state.get("current_tool") or ""
        classification = classify_agent(status, current_tool)
        agents[pane_id] = classification

        target = pane_to_target.get(pane_id, pane_id)
        new_prev_states[target] = classification

        # WORKING → IDLE transition = unread
        if prev_states.get(target) == "working" and classification == "idle":
            unread_targets.add(target)
            unread_changed = True

    # Auto-read: sessions in the active window get marked as read
    for pane_id in agents:
        if pane_to_window.get(pane_id) == active_window:
            target = pane_to_target.get(pane_id, pane_id)
            if target in unread_targets:
                unread_targets.discard(target)
                unread_changed = True

    # Clean stale targets
    current_targets = {pane_to_target.get(pid, pid) for pid in agents}
    stale = unread_targets - current_targets
    if stale:
        unread_targets -= stale
        unread_changed = True

    # Persist
    save_json(PREV_STATE_FILE, new_prev_states)
    if unread_changed:
        save_json(UNREAD_FILE, list(unread_targets))

    # Build per-window display state
    window_agents = defaultdict(list)
    counts = defaultdict(int)

    for pane_id, classification in agents.items():
        window_idx = pane_to_window.get(pane_id)
        if window_idx is None:
            continue

        target = pane_to_target.get(pane_id, pane_id)

        if classification == "needs_input":
            effective = "red"
        elif classification == "idle" and target in unread_targets:
            effective = "orange"
        elif classification == "working":
            effective = "green"
        else:
            counts["grey"] += 1
            continue  # idle + read = no dot

        window_agents[window_idx].append(effective)
        counts[effective] += 1

    # Per-window: take highest priority
    window_states = {}
    for idx, states in window_agents.items():
        best = max(states, key=lambda s: PRIORITY[s])
        window_states[idx] = best

    set_window_options(window_states, all_windows)

    output = format_counters(counts)
    if output:
        print(output, end="")


if __name__ == "__main__":
    main()
