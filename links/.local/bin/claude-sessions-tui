# Active theme — module-level reference used by all rendering code
T: Theme = THEMES["Phosphor"]


def _status_meta() -> dict["Status", tuple[str, str]]:
    return {
        Status.NEEDS_INPUT: ("●", T.attention),
        Status.WORKING:     ("●", T.idle),  # green dot, same as tmux statusline
        Status.IDLE:        ("",  T.idle),   # no icon for idle
    }


# ── Data Types ─────────────────────────────────────────────────────────────────

# Quick-select keys: 1-9 then letters (avoiding q,r,u,p,j,k,tab bindings)
_QUICK_SELECT = "123456789asdfghlzxcvbnm"


@dataclass
class Session:
    target: str       # tmux pane target, e.g. "0:1.0"
    pane_id: str      # tmux pane id, e.g. "%5"
    name: str
    status: Status
    context_pct: str = ""
    cost: str = ""
    turns: str = ""
    preview_lines: list[str] = field(default_factory=list)
    current_tool: str = ""
    claude_pid: int = 0


# ── Discovery & Status Detection ──────────────────────────────────────────────


def _run(cmd: list[str], timeout: float = 5.0) -> str:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def _get_self_pane() -> str:
    return _run(["tmux", "display-message", "-p", "#{session_name}:#{window_index}.#{pane_index}"]).strip()


def _detect_status(captured: str) -> Status:
    """Fallback screen-scraping for sessions without the tmux-statusline plugin."""
    last_lines = "\n".join(captured.splitlines()[-12:])
    if re.search(r"shift\+tab to approve|approve with this feedback|ctrl-g to edit in Vim", last_lines):
        return Status.NEEDS_INPUT
    if re.search(r"esc to interrupt|Allow tool|Do you trust", last_lines):
        return Status.NEEDS_INPUT
    if re.search(r"❯\s+\d+\.\s", last_lines):
        return Status.NEEDS_INPUT
    if re.search(r"ctrl[+-]c to interrupt", last_lines):
        return Status.WORKING
    return Status.IDLE


def _extract_metrics(captured: str) -> tuple[str, str, str]:
    ctx = cost = turns = ""
    if m := re.search(r"🧠\s*(\d+%)", captured):
        ctx = m.group(1)
    if m := re.search(r"💰\s*\$([0-9.]+)", captured):
        cost = f"${m.group(1)}"
    if m := re.search(r"💬\s*(\d+)", captured):
        turns = m.group(1)
    return ctx, cost, turns


_ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def _strip_ansi(s: str) -> str:
    return _ANSI_RE.sub("", s)


from rich.style import Style as RichStyle


def _clean_ansi_bg(text: Text) -> Text:
    """Remove dark/gray backgrounds from parsed Text, keep colorful ones.

    Works at the Rich style level so compound ANSI sequences are handled correctly.
    """
    new_spans = []
    for span in text._spans:
        style = span.style
        if isinstance(style, str):
            new_spans.append(span)
            continue
        if style.bgcolor:
            try:
                tc = style.bgcolor.get_truecolor()
                r, g, b = tc.red, tc.green, tc.blue
                if max(r, g, b) < 50 and (max(r, g, b) - min(r, g, b)) < 25:
                    # Dark gray/black — strip the background, keep everything else
                    style = RichStyle(
                        color=style.color, bold=style.bold, dim=style.dim,
                        italic=style.italic, underline=style.underline,
                        overline=style.overline, strike=style.strike,
                        blink=style.blink, reverse=style.reverse,
                    )
            except (AttributeError, TypeError):
                pass
        new_spans.append(span._replace(style=style))
    text._spans = new_spans
    return text


def _is_chrome(line: str) -> bool:
    """Detect tmux status bar, INSERT mode, bell notification lines."""
    return bool(re.search(r"🧠|💰|💬|-- INSERT --|🔔", _strip_ansi(line)))


def _read_state_files() -> dict[str, dict]:
    """Read all claude-state files, indexed by pane_id."""
    state_dir = Path.home() / ".claude-sessions" / "state"
    if not state_dir.exists():
        return {}
    states = {}
    for pid_dir in state_dir.iterdir():
        if not pid_dir.is_dir():
            continue
        for state_file in pid_dir.glob("*.json"):
            try:
                data = json.loads(state_file.read_text())
                pane_id = data.get("pane_id", "")
                if pane_id:
                    states[pane_id] = data
            except (json.JSONDecodeError, OSError):
                continue
    return states


def _status_from_hook(hook_status: str, current_tool: str) -> Status:
    if hook_status == "working":
        return Status.WORKING
    if hook_status == "waiting" and current_tool in ("permission_prompt", "elicitation_dialog"):
        return Status.NEEDS_INPUT
    # "waiting" from Stop/idle_prompt, "idle", "acknowledged" → all idle from user's POV
    return Status.IDLE


def discover_sessions(self_pane: str, prev: dict[str, Session] | None = None) -> list[Session]:
    pane_output = _run(
        ["tmux", "list-panes", "-a", "-F",
         "#{session_name}:#{window_index}.#{pane_index}\t#{pane_pid}\t#{pane_title}\t#{pane_id}"]
    )
    if not pane_output.strip():
        return []

    prev = prev or {}

    # Batch: get all child processes in one ps call
    pane_infos = []
    pane_pids = set()
    for line in pane_output.strip().splitlines():
        parts = line.split("\t", 3)
        if len(parts) < 4:
            continue
        target, pane_pid_str, title, pane_id = parts
        if target == self_pane:
            continue
        pane_infos.append((target, pane_pid_str, title, pane_id))
        pane_pids.add(pane_pid_str)

    if not pane_infos:
        return []

    ps_output = _run(["ps", "-eo", "pid=,ppid=,comm="])
    # Build parent→child map for claude/happy processes, then walk to deepest descendant
    claude_children: dict[str, list[tuple[str, str]]] = {}  # ppid → [(pid, cmd)]
    for ps_line in ps_output.splitlines():
        ps_line = ps_line.strip()
        if not ps_line:
            continue
        parts = ps_line.split(None, 2)
        if len(parts) == 3:
            pid, ppid, cmd = parts
            if cmd.rsplit("/", 1)[-1] in ("claude", "happy"):
                claude_children.setdefault(ppid, []).append((pid, cmd))

    # For each pane, find the deepest claude/happy descendant
    child_info: dict[str, tuple[str, str]] = {}  # pane_pid → (deepest_pid, cmd)
    for pane_pid in pane_pids:
        if pane_pid not in claude_children:
            continue
        pid, cmd = claude_children[pane_pid][0]
        # Walk down: claude often spawns a child claude, session file is on the inner one
        while pid in claude_children:
            pid, cmd = claude_children[pid][0]
        child_info[pane_pid] = (pid, cmd)

    # Read hook state files
    hook_states = _read_state_files()

    sessions = []
    for target, pane_pid_str, title, pane_id in pane_infos:
        if pane_pid_str not in child_info:
            continue

        claude_pid_str, _ = child_info[pane_pid_str]

        m = re.match(r"^[✳⠂⠐⠈⠁⠄⠠⠃⠅⠆⠇⠉⠊⠋⠌⠍⠎⠏⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟]+\s+(.*)", title)
        name = m.group(1) if m else title

        # Use hook state if available, fall back to screen-scraping
        hook_state = hook_states.get(pane_id, {})
        captured = _run(["tmux", "capture-pane", "-t", target, "-p", "-S", "-12"])
        if hook_state:
            current_tool = hook_state.get("current_tool", "")
            status = _status_from_hook(hook_state.get("status", ""), current_tool)
            if status == Status.IDLE:
                # Grace period: when transitioning from WORKING → IDLE,
                # hold WORKING briefly so dialogs have time to render.
                prev_session = prev.get(target) if prev else None
                if prev_session and prev_session.status == Status.WORKING:
                    status_since = hook_state.get("status_since", "")
                    if status_since:
                        try:
                            ts = datetime.fromisoformat(status_since.replace("Z", "+00:00"))
                            if (datetime.now(timezone.utc) - ts).total_seconds() < 3.0:
                                status = Status.WORKING
                        except (ValueError, TypeError):
                            pass
                # Screen-scrape safety net: catch NEEDS_INPUT that hooks missed
                if status == Status.IDLE:
                    if _detect_status(captured) == Status.NEEDS_INPUT:
                        status = Status.NEEDS_INPUT
        else:
            status = _detect_status(captured)
            current_tool = ""

        ctx, cost, turns = _extract_metrics(captured)
        # Carry over metrics from previous refresh if current capture missed them
        if not ctx and not cost and not turns and target in prev:
            p = prev[target]
            ctx, cost, turns = p.context_pct, p.cost, p.turns

        sessions.append(Session(
            target=target, pane_id=pane_id, name=name, status=status,
            context_pct=ctx, cost=cost, turns=turns,
            preview_lines=[],
            current_tool=current_tool,
            claude_pid=int(claude_pid_str),
        ))

    # Sort by tmux pane order (session:window.pane)
    def pane_sort_key(s: Session) -> tuple:
        parts = s.target.replace(":", ".").split(".")
        return tuple(int(p) if p.isdigit() else p for p in parts)

    sessions.sort(key=pane_sort_key)
    return sessions


# ── Unread Tracking ──────────────────────────────────────────────────────────


_CACHE_DIR = Path.home() / ".cache" / "claude-sessions"

_UNREAD_FILE = _CACHE_DIR / "unread.json"
_UNREAD_PROTECTED_FILE = _CACHE_DIR / "unread-protected.json"
_LOG_FILE = _CACHE_DIR / "unread.log"
_LOG_ENABLED = True


def _log(msg: str) -> None:
    if not _LOG_ENABLED:
        return
    try:
        _CACHE_DIR.mkdir(parents=True, exist_ok=True)
        with open(_LOG_FILE, "a") as f:
            f.write(f"{datetime.now().strftime('%H:%M:%S')} TUI: {msg}\n")
    except OSError:
        pass


def _load_unread() -> set[str]:
    try:
        return set(json.loads(_UNREAD_FILE.read_text()))
    except (json.JSONDecodeError, OSError):
        return set()


def _save_unread(targets: set[str]) -> None:
    _CACHE_DIR.mkdir(parents=True, exist_ok=True)
    _UNREAD_FILE.write_text(json.dumps(list(targets)))


def _load_protected() -> set[str]:
    try:
        return set(json.loads(_UNREAD_PROTECTED_FILE.read_text()))
    except (json.JSONDecodeError, OSError):
        return set()


_THEME_FILE = _CACHE_DIR / "theme.json"


def _load_theme_name() -> str:
    try:
        return json.loads(_THEME_FILE.read_text()).get("theme", "Phosphor")
    except (json.JSONDecodeError, OSError):
        return "Phosphor"


def _save_theme_name(name: str) -> None:
    _CACHE_DIR.mkdir(parents=True, exist_ok=True)
    _THEME_FILE.write_text(json.dumps({"theme": name}))


def _set_theme(name: str) -> None:
    """Set the active theme globally."""
    global T
    T = THEMES.get(name, THEMES["Phosphor"])


# Initialize theme from persisted setting
_set_theme(_load_theme_name())


# ── Widgets ────────────────────────────────────────────────────────────────────


class SessionCard(ListItem):
    """Multi-line session card. Uses render() for proper background highlight."""

    DEFAULT_CSS = """
    SessionCard {
        height: 6;
        padding: 0 1;
    }
    """

    def __init__(self, session: Session, spinner_frame: int = 0, index: int = 0, unread: bool = False) -> None:
        super().__init__()
        self.session = session
        self._spinner_frame = spinner_frame
        self._target = session.target
        self._index = index
        self._unread = unread
        self.styles.background = self._card_bg(highlighted=False)

    def _card_bg(self, highlighted: bool) -> str:
        if highlighted:
            return T.highlight_bg
        if self.session.status == Status.NEEDS_INPUT:
            return T.attention_bg
        if self._unread and self.session.status == Status.IDLE:
            return T.unread_bg
        return T.bg

    def render(self) -> Text:
        s = self.session
        icon, color = _status_meta()[s.status]
        hl = self.highlighted
        unread = self._unread and s.status != Status.NEEDS_INPUT
        bar = "▎" if hl else " "
        bar_style = f"bold {T.highlight_bar}" if hl else ""
        text = Text()

        # Line 1: top spacing
        text.append(bar, style=bar_style)
        text.append("\n")

        # Line 2: bar + index + icon + [unread dot] + name
        text.append(bar, style=bar_style)
        text.append(" ")

        if self._index < len(_QUICK_SELECT):
            text.append(f"{_QUICK_SELECT[self._index]} ", style=T.text_dim)

        if s.status == Status.WORKING:
            # Blinking green dot — alternate visibility
            if self._spinner_frame % 6 < 4:
                text.append("● ", style=f"bold {T.idle}")
            else:
                text.append("  ", style="")
        elif s.status == Status.NEEDS_INPUT:
            text.append("● ", style=f"bold {T.attention}")
        elif unread:
            text.append("● ", style=T.unread_dot)
        else:
            text.append("  ", style="")

        name_color = "#ffffff" if hl or unread else T.text
        text.append(s.name, style=f"bold {name_color}")
        text.append("\n")

        # Line 3: bar + status description
        text.append(bar, style=bar_style)
        text.append("  ")

        if s.current_tool and s.status == Status.WORKING:
            text.append(s.current_tool, style=T.text_dim)
        elif s.status == Status.NEEDS_INPUT:
            text.append("needs your input", style=T.attention)
        elif s.status == Status.WORKING:
            text.append("working...", style=T.text_dim)
        elif unread:
            text.append("unread", style=T.unread_dot)
        else:
            text.append("idle", style=T.text_dim)
        text.append(f"  {s.target}", style=T.text_dim)
        text.append("\n")

        # Line 4: bar + metrics
        text.append(bar, style=bar_style)
        text.append("  ")
        metrics = []
        if s.context_pct:
            metrics.append(f"🧠 {s.context_pct}")
        if s.cost:
            metrics.append(f"💰 {s.cost}")
        if s.turns:
            metrics.append(f"💬 {s.turns}")
        text.append(" · ".join(metrics) if metrics else "", style=T.text_dim)
        text.append("\n")

        # Line 5: bottom spacing with bar
        text.append(bar, style=bar_style)

        return text

    def watch_highlighted(self, value: bool) -> None:
        """Programmatically set background."""
        self.styles.background = self._card_bg(value)

    def update_session(self, session: Session, spinner_frame: int, unread: bool | None = None) -> None:
        self.session = session
        self._spinner_frame = spinner_frame
        if unread is not None:
            self._unread = unread
        self.styles.background = self._card_bg(self.highlighted)
        self.refresh()


class PreviewPanel(RichLog):
    """Live mirror of selected session's tmux pane. Auto-scrolls to bottom."""

    DEFAULT_CSS = """
    PreviewPanel {
        height: 100%;
        padding: 0 1;
        scrollbar-size: 0 0;
    }
    """

    _last_text: str = ""

    @staticmethod
    def _normalize(s: str) -> str:
        s = re.sub(r"\x1b\[[^a-zA-Z]*[a-zA-Z]", "", s)  # strip ANSI
        s = re.sub(r".*🔔.*", "", s)  # strip any bell notification line
        s = re.sub(r"\n\s*\n", "\n", s).strip()  # collapse blank lines
        return s

    def update_live(self, ansi_content: str) -> None:
        """Update with raw ANSI content from tmux capture-pane -e."""
        stripped = self._normalize(ansi_content)
        if stripped == self._last_text:
            return
        self._last_text = stripped
        self.clear()
        if not ansi_content.strip():
            self.write(Text("No output", style=T.text_dim))
            return
        text = Text.from_ansi(ansi_content)
        _clean_ansi_bg(text)
        self.write(text)



# ── Main App ───────────────────────────────────────────────────────────────────


class SessionTracker(App[None]):

    CSS = """
    Screen { background: #101014; }
    #title-bar {
        dock: top; height: 3;
        background: #181820; color: #ccccd6;
        padding: 1 2;
    }
    #key-bar {
        dock: bottom; height: 3;
        background: #181820; color: #787d87;
        padding: 1 1;
    }
    #main { height: 1fr; }
    #sidebar {
        width: 20%;
        border-right: solid #303040;
        background: #101014;
    }
    #session-list {
        background: #101014;
        scrollbar-size: 1 1;
    }
    #session-list > ListItem {
        background: #101014;
    }
    #session-list > ListItem.-highlight {
        background: #122850;
    }
    #session-list:focus > ListItem.-highlight {
        background: #122850;
    }
    #session-list > ListItem:hover {
        background: #16161d;
    }
    #preview-container {
        width: 80%;
        background: #101014;
    }
    """

    ENABLE_COMMAND_PALETTE = False

    BINDINGS = [
        Binding("q", "quit", "Quit"),
        Binding("r", "refresh", "Refresh"),
        Binding("u", "toggle_unread", "Unread"),
        Binding("t", "toggle_theme", "Theme", show=False),
        Binding("p", "toggle_palette", "Palette", show=False),
        Binding("tab", "toggle_focus", "Focus", priority=True),
        Binding("j", "move_down", "Down", show=False),
        Binding("k", "move_up", "Up", show=False),
    ]

    def __init__(self) -> None:
        super().__init__()
        self._self_pane = _get_self_pane()
        self._sessions: list[Session] = []
        self._session_map: dict[str, Session] = {}
        self._spinner_frame = 0
        self._refresh_count = 0
        self._preview_focused = False
        self._palette_mode = False
        self._theme_mode = False
        self._preview_debounce = None
        self._stop = threading.Event()
        # Unread tracking (persisted to disk)
        self._unread_targets: set[str] = _load_unread()
        self._prev_statuses: dict[str, Status] = {}  # target → last known status
        self._manual_unread_target: str | None = None  # prevents dwell from clearing
        self._read_pending_target: str | None = None
        self._read_pending_since: float = 0.0

    def compose(self) -> ComposeResult:
        yield Static("", id="title-bar")
        with Horizontal(id="main"):
            with Vertical(id="sidebar"):
                yield ListView(id="session-list")
            yield PreviewPanel(id="preview-container")
        yield Static("", id="key-bar")

    def on_mount(self) -> None:
        self._apply_theme()
        self._do_refresh()
        self.query_one("#session-list", ListView).focus()
        self._start_refresh_loop()
        self.set_interval(0.1, self._tick_spinner)
        self.set_interval(0.3, self._tick_preview)
        self.set_interval(0.5, self._tick_dwell)

    def _apply_theme(self) -> None:
        """Apply the active theme to all widgets programmatically."""
        try:
            self.screen.styles.background = T.bg
            title = self.query_one("#title-bar", Static)
            title.styles.background = T.surface
            title.styles.color = T.text
            key = self.query_one("#key-bar", Static)
            key.styles.background = T.surface
            key.styles.color = T.text_dim
            sidebar = self.query_one("#sidebar")
            sidebar.styles.background = T.bg
            sidebar.styles.border_right = ("solid", T.border)
            lv = self.query_one("#session-list", ListView)
            lv.styles.background = T.bg
            preview = self.query_one("#preview-container")
            preview.styles.background = T.bg
        except NoMatches:
            pass
        self._update_title_bar(len(self._sessions))
        self._update_key_bar()
        # Refresh all cards with new theme colors
        try:
            lv = self.query_one("#session-list", ListView)
            for child in lv.children:
                if isinstance(child, SessionCard):
                    child.styles.background = child._card_bg(child.highlighted)
                    child.refresh()
        except NoMatches:
            pass

    def _update_title_bar(self, count: int) -> None:
        text = Text()
        text.append(" ⚡ ", style=f"bold {T.primary}")
        text.append("Claude Sessions", style=f"bold {T.text}")
        if count:
            text.append(f"  ({count})", style=T.text_dim)

        # Status counts
        counts: dict[Status, int] = {}
        for s in self._sessions:
            counts[s.status] = counts.get(s.status, 0) + 1
        unread_count = sum(1 for s in self._sessions if s.target in self._unread_targets)
        # Subtract unread from idle so they don't double-count
        idle_count = counts.get(Status.IDLE, 0) - unread_count
        if Status.NEEDS_INPUT in counts:
            text.append("  ● ", style=f"bold {T.attention}")
            text.append(f"{counts[Status.NEEDS_INPUT]} needs input", style=T.text_dim)
        if Status.WORKING in counts:
            text.append("  ● ", style=f"bold {T.idle}")
            text.append(f"{counts[Status.WORKING]} working", style=T.text_dim)
        if unread_count:
            text.append("  ● ", style=T.unread_dot)
            text.append(f"{unread_count} unread", style=T.text_dim)
        if idle_count > 0:
            text.append(f"  {idle_count} idle", style=T.text_dim)
        try:
            self.query_one("#title-bar", Static).update(text)
        except NoMatches:
            pass

    def _update_key_bar(self) -> None:
        text = Text()
        if self._preview_focused:
            keys = [("Tab", "Sidebar"), ("↵", "Jump"), ("q", "Back")]
            text.append(" 🔵 PREVIEW MODE ", style=f"bold {T.highlight_bar}")
            text.append(" — keys forwarded to session ", style=T.text_dim)
        else:
            keys = [("q", "Quit"), ("↵", "Jump"), ("1-9/a-m", "Select"), ("u", "Unread"), ("t", "Theme"), ("Tab", "Preview"), ("r", "Refresh")]
        for i, (key, label) in enumerate(keys):
            if self._preview_focused and i == 0:
                pass  # already added the mode indicator
            else:
                if text.plain:
                    text.append(" · ", style=T.border)
            text.append(f" {key} ", style=f"bold {T.primary}")
            text.append(label, style=T.text_dim)
        try:
            self.query_one("#key-bar", Static).update(text)
        except NoMatches:
            pass

    def _tick_spinner(self) -> None:
        self._spinner_frame = (self._spinner_frame + 1) % len(SPINNER)
        # Only update cards for working sessions (lightweight)
        try:
            lv = self.query_one("#session-list", ListView)
            for child in lv.children:
                if isinstance(child, SessionCard) and child.session.status == Status.WORKING:
                    child.update_session(child.session, self._spinner_frame)
        except NoMatches:
            pass

    @work(thread=True)
    def _start_refresh_loop(self) -> None:
        """Background thread: poll every 2s, post results to main thread."""
        while not self._stop.wait(2.0):
            try:
                sessions = discover_sessions(self._self_pane, self._session_map)
                self.call_from_thread(self._reconcile_list, sessions)
            except Exception:
                pass

    def _do_refresh(self) -> None:
        sessions = discover_sessions(self._self_pane, self._session_map)
        self._reconcile_list(sessions)

    def _reconcile_list(self, sessions: list[Session]) -> None:
        if self._palette_mode or self._theme_mode:
            return
        self._refresh_count += 1
        self._sessions = sessions
        self._session_map = {s.target: s for s in sessions}

        # Sync unread from disk (pick up external changes from toggle script)
        self._unread_targets = _load_unread()

        # Detect WORKING → IDLE transitions → mark unread
        unread_changed = False
        for s in sessions:
            prev_status = self._prev_statuses.get(s.target)
            if prev_status == Status.WORKING and s.status == Status.IDLE:
                self._unread_targets.add(s.target)
                unread_changed = True
                _log(f"UNREAD+ {s.target} (working→idle transition)")
            self._prev_statuses[s.target] = s.status

        # Check tmux pane focus — if user is directly viewing a pane, mark it read
        self._check_pane_focus(sessions)

        # Clean up stale targets
        current_targets = {s.target for s in sessions}
        stale = self._unread_targets - current_targets
        if stale:
            unread_changed = True
            _log(f"UNREAD- {stale} (stale targets)")
        self._unread_targets &= current_targets
        self._prev_statuses = {t: st for t, st in self._prev_statuses.items() if t in current_targets}
        if unread_changed:
            _save_unread(self._unread_targets)

        lv = self.query_one("#session-list", ListView)

        # Build map of existing cards by target
        existing: dict[str, SessionCard] = {}
        for child in lv.children:
            if isinstance(child, SessionCard):
                existing[child._target] = child

        new_targets = [s.target for s in sessions]
        old_targets = list(existing.keys())

        if new_targets == old_targets:
            # Same sessions in same order — update cards in place (preserves selection)
            for s in sessions:
                if s.target in existing:
                    existing[s.target].update_session(s, self._spinner_frame, unread=s.target in self._unread_targets)
        else:
            # Sessions changed — rebuild list
            selected_target = None
            if lv.highlighted_child and isinstance(lv.highlighted_child, SessionCard):
                selected_target = lv.highlighted_child._target

            lv.clear()
            for i, s in enumerate(sessions):
                card = SessionCard(s, self._spinner_frame, index=i, unread=s.target in self._unread_targets)
                card._target = s.target
                lv.append(card)

            # Restore selection
            if selected_target and lv.children:
                for i, child in enumerate(lv.children):
                    if isinstance(child, SessionCard) and child._target == selected_target:
                        lv.index = i
                        break
            elif lv.children:
                lv.index = 0

        # Force-refresh the highlighted card's visuals (fixes stale highlight
        # after switching back from another tmux window)
        hl_child = lv.highlighted_child
        if isinstance(hl_child, SessionCard):
            hl_child.styles.background = hl_child._card_bg(True)
            hl_child.refresh()

        self._update_title_bar(len(sessions))
        self._tick_preview()

    def _check_pane_focus(self, sessions: list[Session]) -> None:
        """Check if the user is directly focused on any session's tmux pane."""
        # Get client activity to detect idle (>2min = not watching)
        client_activity = _run(["tmux", "list-clients", "-F", "#{client_activity}"])
        if not client_activity.strip():
            return  # no clients attached
        try:
            latest = max(int(ts) for ts in client_activity.strip().splitlines() if ts.strip())
            if datetime.now(timezone.utc).timestamp() - latest > 120:
                return  # client idle
        except (ValueError, TypeError):
            return

        # Check which panes have their window active
        pane_active = _run(["tmux", "list-panes", "-a", "-F", "#{session_name}:#{window_index}.#{pane_index}\t#{window_active}"])
        active_panes: set[str] = set()
        for line in pane_active.strip().splitlines():
            parts = line.split("\t", 1)
            if len(parts) == 2 and parts[1] == "1":
                active_panes.add(parts[0])

        protected = _load_protected()
        changed = False
        for s in sessions:
            if s.target in active_panes and s.target in self._unread_targets:
                if s.target not in protected:
                    self._unread_targets.discard(s.target)
                    changed = True
                    _log(f"UNREAD- {s.target} (pane focus, active window)")
        if changed:
            _save_unread(self._unread_targets)

    def _get_selected_session(self) -> Session | None:
        lv = self.query_one("#session-list", ListView)
        child = lv.highlighted_child
        if isinstance(child, SessionCard):
            return child.session
        return None

    def _tick_preview(self) -> None:
        """Fast poll: live-capture the selected session's pane with ANSI colors."""
        session = self._get_selected_session()
        if not session:
            return
        try:
            preview = self.query_one("#preview-container", PreviewPanel)
        except NoMatches:
            return
        # -J joins wrapped lines, -S -200 captures scrollback to fill the preview
        ansi = _run(["tmux", "capture-pane", "-e", "-p", "-J", "-S", "-200", "-t", session.target])
        # Trim blank lines from bottom
        lines = ansi.split("\n")
        while lines and not _strip_ansi(lines[-1]).strip():
            lines.pop()
        # Strip tmux chrome: status bar, INSERT mode, bell notification
        while lines and _is_chrome(lines[-1]):
            lines.pop()
        # Trim any new trailing blanks after stripping
        while lines and not _strip_ansi(lines[-1]).strip():
            lines.pop()
        preview.update_live("\n".join(lines))

    def _tick_dwell(self) -> None:
        """Check dwell time: mark session as read after ~1.5s of staying on it."""
        session = self._get_selected_session()
        if not session:
            return
        target = session.target
        if target != self._read_pending_target:
            # Selection changed — reset dwell timer, clear manual unread protection
            if self._manual_unread_target and self._manual_unread_target != target:
                self._manual_unread_target = None
            self._read_pending_target = target
            self._read_pending_since = datetime.now(timezone.utc).timestamp()
            return
        if self._manual_unread_target == target:
            return  # manual unread — don't auto-clear
        if target not in self._unread_targets:
            return  # already read
        elapsed = datetime.now(timezone.utc).timestamp() - self._read_pending_since
        if elapsed >= 1.5:
            self._unread_targets.discard(target)
            _log(f"UNREAD- {target} (dwell 1.5s met in sidebar)")
            _save_unread(self._unread_targets)
            self._refresh_card(target)

    def _refresh_card(self, target: str) -> None:
        """Refresh a single card's unread visual state."""
        try:
            lv = self.query_one("#session-list", ListView)
            for child in lv.children:
                if isinstance(child, SessionCard) and child._target == target:
                    child._unread = target in self._unread_targets
                    child.styles.background = child._card_bg(child.highlighted)
                    child.refresh()
                    break
        except NoMatches:
            pass

    def on_list_view_highlighted(self, _event: ListView.Highlighted) -> None:
        # Live theme preview
        if self._theme_mode:
            lv = self.query_one("#session-list", ListView)
            child = lv.highlighted_child
            if isinstance(child, ListItem):
                idx = lv.index
                theme_names = list(THEMES.keys())
                if idx is not None and 0 <= idx < len(theme_names):
                    _set_theme(theme_names[idx])
                    self._apply_theme()
            return

        # Reset dwell timer on selection change
        session = self._get_selected_session()
        if session:
            # Clear manual unread protection when navigating away
            if self._manual_unread_target and self._manual_unread_target != session.target:
                self._manual_unread_target = None
            self._read_pending_target = session.target
            self._read_pending_since = datetime.now(timezone.utc).timestamp()
        try:
            self.query_one("#preview-container", PreviewPanel)._last_text = ""
        except NoMatches:
            pass
        self._tick_preview()

    def action_toggle_focus(self) -> None:
        self._preview_focused = not self._preview_focused
        self._update_key_bar()
        # Visual indicator: change sidebar border color
        try:
            sidebar = self.query_one("#sidebar")
            if self._preview_focused:
                sidebar.styles.border_right = ("solid", T.highlight_bar)
            else:
                sidebar.styles.border_right = ("solid", T.border)
        except NoMatches:
            pass

    def on_key(self, event: events.Key) -> None:
        """Handle enter for both modes, and forward keys in preview mode."""
        if event.key == "enter":
            event.prevent_default()
            event.stop()
            if self._preview_focused:
                # Forward enter to the session pane
                session = self._get_selected_session()
                if session:
                    _run(["tmux", "send-keys", "-t", session.target, "Enter"])
                    self._tick_preview()
            else:
                # Jump to pane
                self.action_jump()
            return

        # Quick-select: 1-9 then a,s,d,f,g,h,l,z,x,c,v,b,n,m for sessions 10+
        if not self._preview_focused and event.character and event.character in _QUICK_SELECT:
            idx = _QUICK_SELECT.index(event.character)
            lv = self.query_one("#session-list", ListView)
            if idx < len(lv.children):
                lv.index = idx
            event.prevent_default()
            event.stop()
            return

        # In preview mode, forward q to the pane instead of quitting
        if event.key == "q" and self._preview_focused:
            event.prevent_default()
            event.stop()
            session = self._get_selected_session()
            if session:
                _run(["tmux", "send-keys", "-t", session.target, "-l", "q"])
                self._tick_preview()
            return

        if not self._preview_focused:
            return

        # Don't forward tab — it exits preview mode
        if event.key == "tab":
            return

        session = self._get_selected_session()
        if not session:
            return
        # Map Textual key names to tmux send-keys format
        key = event.key
        key_map = {
            "up": "Up", "down": "Down", "left": "Left", "right": "Right",
            "escape": "Escape", "backspace": "BSpace", "delete": "DC",
            "home": "Home", "end": "End", "pageup": "PPage", "pagedown": "NPage",
            "space": "Space",
        }
        if key in key_map:
            _run(["tmux", "send-keys", "-t", session.target, key_map[key]])
        elif event.character and len(event.character) == 1:
            _run(["tmux", "send-keys", "-t", session.target, "-l", event.character])
        event.prevent_default()
        event.stop()
        self._tick_preview()

    def action_move_down(self) -> None:
        self.query_one("#session-list", ListView).action_cursor_down()

    def action_move_up(self) -> None:
        self.query_one("#session-list", ListView).action_cursor_up()

    def action_refresh(self) -> None:
        self._do_refresh()

    def action_toggle_unread(self) -> None:
        session = self._get_selected_session()
        if not session:
            return
        target = session.target
        if target in self._unread_targets:
            self._unread_targets.discard(target)
            self._manual_unread_target = None
            _log(f"UNREAD- {target} (manual toggle in TUI)")
        else:
            self._unread_targets.add(target)
            _log(f"UNREAD+ {target} (manual toggle in TUI)")
            self._manual_unread_target = target
        _save_unread(self._unread_targets)
        self._refresh_card(target)

    # ── Theme picker ────────────────────────────────────────────────────────

    def action_toggle_theme(self) -> None:
        self._theme_mode = not self._theme_mode
        lv = self.query_one("#session-list", ListView)
        lv.clear()
        if self._theme_mode:
            current_idx = 0
            for i, (name, theme) in enumerate(THEMES.items()):
                if name == T.name:
                    current_idx = i
                item = ListItem(Static(""))
                lv.append(item)
                txt = Text()
                txt.append("  ", style="")
                # Color swatch showing key theme colors
                txt.append("██", style=theme.bg)
                txt.append("██", style=theme.surface)
                txt.append("██", style=theme.primary)
                txt.append("██", style=theme.working)
                txt.append("██", style=theme.idle)
                txt.append("██", style=theme.attention)
                txt.append(f"  {name}", style=f"bold {theme.text}")
                if name == T.name:
                    txt.append(" ✓", style=f"bold {theme.primary}")
                item.query_one(Static).update(txt)
                item.styles.height = 2
                item.styles.background = theme.bg
            if lv.children:
                lv.index = current_idx
        else:
            # Exiting theme mode — persist the current theme
            _save_theme_name(T.name)
            self._apply_theme()
            self._do_refresh()

