"""
claude-sessions-tui — ae-inspired TUI for managing concurrent Claude Code sessions in tmux.

Discovers Claude/Happy processes in tmux panes, shows their status in a
chat-app-like interface, and lets you jump to them or send input.
"""

from __future__ import annotations

import json
import os

# Force true color support — tmux/SSH don't always set COLORTERM
os.environ.setdefault("COLORTERM", "truecolor")

import re
import subprocess
import threading
from dataclasses import dataclass, field
from datetime import datetime, timezone
from enum import IntEnum
from pathlib import Path

from rich.text import Text
from textual import events, work
from textual.app import App, ComposeResult
from textual.binding import Binding
from textual.containers import Horizontal, Vertical
from textual.css.query import NoMatches
from textual.widgets import ListItem, ListView, RichLog, Static


# ── Theme ──────────────────────────────────────────────────────────────────────

SPINNER = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"


class Status(IntEnum):
    NEEDS_INPUT = 1
    WORKING = 2
    IDLE = 3


@dataclass(frozen=True)
class Theme:
    name: str
    bg: str            # base background (cards, sidebar, screen)
    surface: str       # elevated surfaces (title bar, key bar)
    border: str        # borders, separators
    text: str          # primary text
    text_dim: str      # secondary/dim text
    primary: str       # accent color (keybindings, title icon)
    highlight_bg: str  # selected card background
    highlight_bar: str # left bar on selected card
    attention: str     # needs-input text color
    attention_bg: str  # needs-input card background
    unread_bg: str     # unread card background
    unread_dot: str    # unread dot color
    working: str       # working status color
    idle: str          # idle status color
    hover: str         # card hover background


