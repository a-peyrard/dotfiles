    def action_toggle_palette(self) -> None:
        self._palette_mode = not self._palette_mode
        lv = self.query_one("#session-list", ListView)
        lv.clear()
        if self._palette_mode:
            for hex_color, label in self._PALETTE:
                item = ListItem(Static(""))
                lv.append(item)
                # Render a swatch: colored block + label
                txt = Text()
                txt.append("  ████  ", style=f"bold {hex_color}")
                txt.append(f" {hex_color} ", style=f"bold {T.text}")
                txt.append(label, style=T.text_dim)
                item.query_one(Static).update(txt)
                item.styles.height = 2
                item.styles.background = T.bg
            # Also show them as highlight backgrounds
            lv.append(ListItem(Static(Text("\n── As card backgrounds ──", style=T.text_dim))))
            for hex_color, label in self._PALETTE[-20:]:
                item = ListItem(Static(""))
                lv.append(item)
                txt = Text()
                txt.append(f"  ❓ needs your input  ", style="#ffffff")
                txt.append(f"  {hex_color} {label}", style=T.text_dim)
                item.query_one(Static).update(txt)
                item.styles.height = 2
                item.styles.background = hex_color
            if lv.children:
                lv.index = 0
        else:
            self._do_refresh()

    def action_quit(self) -> None:
        self._stop.set()
        self.exit()

    def action_jump(self) -> None:
        session = self._get_selected_session()
        if not session:
            return
        t = session.target
        s, wp = t.split(":", 1)
        w = wp.split(".")[0]
        _run(["tmux", "select-window", "-t", f"{s}:{w}"])
        _run(["tmux", "select-pane", "-t", t])



# ── Entry Point ────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    if not os.environ.get("TMUX"):
        print("Error: must be run inside tmux")
        raise SystemExit(1)
    SessionTracker().run()
