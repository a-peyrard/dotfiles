#
# Auto-start devbridge server (devserver side — listens for Mac commands)
# Uses zsh/net/tcp port probe instead of pgrep -f (~4ms vs ~60ms on busy devservers)
#

if ! command -v devbridge > /dev/null 2>&1; then
    return
fi

zmodload -s zsh/net/tcp
if ! ztcp 127.0.0.1 9999 2>/dev/null; then
    nohup devbridge server >> /tmp/devbridge.log 2>&1 &
    disown
else
    ztcp -c $REPLY 2>/dev/null
fi
