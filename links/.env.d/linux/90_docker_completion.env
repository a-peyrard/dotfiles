# Docker completion (must load after compinit)
# Cache the output to avoid forking docker on every startup
if command -v docker &>/dev/null; then
    _docker_cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/docker_completion.zsh"
    if [[ ! -f "$_docker_cache" || "$(command -v docker)" -nt "$_docker_cache" ]]; then
        mkdir -p "${_docker_cache:h}"
        docker completion zsh > "$_docker_cache" 2>/dev/null
    fi
    [[ -f "$_docker_cache" ]] && source "$_docker_cache"
    unset _docker_cache
fi
