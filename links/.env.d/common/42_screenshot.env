#
# Screenshot capture and upload to a remote host
# Requires: screencapture (macOS), scp
# Set SS_REMOTE_TARGET to default destination (e.g., user@host)
#

ss-remote() {
  local capture_flags="-i"
  if [[ "$1" == "-w" ]]; then
    capture_flags="-iW"
    shift
  fi

  local filename="ss_$(date +%s).png"
  local local_file="/tmp/$filename"

  screencapture $capture_flags "$local_file" || return 1
  [[ -f "$local_file" ]] || return 0

  devbridge send file-receive filename="$filename" data=@"$local_file" && {
    echo "/tmp/$filename" | pbcopy
    echo "Uploaded: /tmp/$filename (copied to clipboard)"
  }
}
