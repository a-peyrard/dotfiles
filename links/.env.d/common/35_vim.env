# export VIM_HOME
if [ "$OS_TYPE" = "macos" ]; then
  export VIM_HOME=$HOMEBREW_PREFIX/Cellar/vim
else
  # On Linux, vim is typically in standard locations
  export VIM_HOME=/usr/share/vim
fi

# Create vless alias to use vim as a pager (cross-platform)
if [ -d "$VIM_HOME" ]; then
  local _less_sh=("$VIM_HOME"/**/less.sh(NY1))
  [[ -n "$_less_sh" ]] && alias vless="$_less_sh"
fi
