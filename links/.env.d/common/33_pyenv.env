#!/usr/bin/env zsh

# Lazy-load pyenv: shims on PATH immediately, full init deferred to first use
if command -v pyenv &>/dev/null; then
    export PYENV_SHELL=zsh
    export PATH="$HOME/.pyenv/shims:$PATH"
    pyenv() {
        unfunction pyenv
        eval "$(command pyenv init -)"
        pyenv "$@"
    }
fi